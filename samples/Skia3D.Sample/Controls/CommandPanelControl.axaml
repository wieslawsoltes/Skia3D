<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Skia3D.Sample"
             xmlns:controls="clr-namespace:Skia3D.Sample.Controls"
             xmlns:vm="clr-namespace:Skia3D.Sample.ViewModels"
             mc:Ignorable="d"
             x:Class="Skia3D.Sample.Controls.CommandPanelControl"
             x:DataType="vm:CommandPanelViewModel">
    <Border Margin="0,8,8,8"
            VerticalAlignment="Stretch"
            Width="320"
            ClipToBounds="True"
            Background="#2D3238"
            BorderBrush="#1F2328"
            BorderThickness="1"
            CornerRadius="2"
            BoxShadow="0 8 18 0 #33000000">
        <Grid>
            <TabControl Classes="CommandTabs" TabStripPlacement="Top">
                <TabItem Classes="CommandTab" ToolTip.Tip="Create">
                    <TabItem.Header>
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <Viewbox Width="18" Height="18">
                                <Path Classes="CommandTabIcon" Data="M6,1 V11 M1,6 H11"/>
                            </Viewbox>
                            <TextBlock Classes="CommandTabLabel" Text="Create"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.IsScrollChainingEnabled="False"
                                  Padding="10">
                        <StackPanel Spacing="8">
                            <Expander Classes="InspectorRollout" Header="Scene" IsExpanded="True">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="SectionLabel" Text="Quick scene actions"/>
                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                                        <Button Content="Load" Classes="InspectorButton" Command="{Binding Actions.LoadObjCommand}"/>
                                        <Button Content="Zoom Extents" Classes="InspectorButton" Command="{Binding Actions.ZoomExtentsCommand}" Grid.Column="1"/>
                                        <Button Content="Clear Scene" Classes="InspectorButton" Command="{Binding Actions.ClearSceneCommand}" Grid.Row="1" Grid.ColumnSpan="2"/>
                                    </Grid>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Import" IsExpanded="False">
                                <StackPanel Spacing="6">
                                    <CheckBox x:Name="ImportCenterToggle" Content="Center to origin" IsChecked="{Binding Options.ImportCenter, Mode=TwoWay}" Foreground="#E8EEF5"/>
                                    <CheckBox x:Name="ImportNormalsToggle" Content="Recalculate normals" IsChecked="{Binding Options.ImportNormals, Mode=TwoWay}" Foreground="#E8EEF5"/>
                                    <CheckBox x:Name="ImportScaleToggle" Content="Scale to radius" IsChecked="{Binding Options.ImportScaleEnabled, Mode=TwoWay}" Foreground="#E8EEF5"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="ImportScaleLabel" Text="{Binding Options.ImportScaleLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="ImportScaleSlider"
                                                Minimum="0.1"
                                                Maximum="10"
                                                Value="{Binding Options.ImportScaleRadius, Mode=TwoWay}"
                                                TickFrequency="0.1"
                                                SmallChange="0.1"
                                                LargeChange="0.5"
                                                IsEnabled="{Binding Options.ImportScaleEnabled}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Classes="CommandTab" IsSelected="True" ToolTip.Tip="Modify">
                    <TabItem.Header>
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <Viewbox Width="18" Height="18">
                                <Path Classes="CommandTabIcon" Data="M2,10 L10,2 M3,11 L1,13 L3,13 Z"/>
                            </Viewbox>
                            <TextBlock Classes="CommandTabLabel" Text="Modify"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.IsScrollChainingEnabled="False"
                                  Padding="10">
                        <StackPanel Spacing="8">
                            <Expander Classes="InspectorRollout" Header="Selection" IsExpanded="True">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="SelectionLabel" Text="{Binding Editor.SelectionSummary}" Foreground="#A3AFBD"/>
                                    <TextBlock Classes="SectionLabel" Text="Box/Lasso: drag · Paint: sweep · Shift/Ctrl add/subtract"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionTitle" Text="Paint selection"/>
                                        <TextBlock x:Name="PaintRadiusLabel" Text="{Binding Options.PaintRadiusLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="PaintRadiusSlider"
                                                Minimum="6"
                                                Maximum="120"
                                                Value="{Binding Options.PaintRadius, Mode=TwoWay}"
                                                TickFrequency="2"
                                                SmallChange="2"
                                                LargeChange="6"/>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Edge Loop Select"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.SelectEdgeLoopCommand}"
                                                IsEnabled="{Binding Commands.CanSelectEdgeLoop}"/>
                                        <Button Content="Edge Ring Select"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.SelectEdgeRingCommand}"
                                                IsEnabled="{Binding Commands.CanSelectEdgeRing}"/>
                                    </Grid>
                                    <TextBlock Classes="SectionTitle" Text="Selection utilities"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Grow Selection"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.GrowSelectionCommand}"
                                                IsEnabled="{Binding Commands.CanGrowSelection}"/>
                                        <Button Content="Shrink Selection"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.ShrinkSelectionCommand}"
                                                IsEnabled="{Binding Commands.CanShrinkSelection}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                        <Button Content="To Vertices"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.ConvertSelectionToVerticesCommand}"
                                                IsEnabled="{Binding Commands.CanConvertSelection}"/>
                                        <Button Content="To Edges"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.ConvertSelectionToEdgesCommand}"
                                                IsEnabled="{Binding Commands.CanConvertSelection}"/>
                                        <Button Content="To Faces"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.ConvertSelectionToFacesCommand}"
                                                IsEnabled="{Binding Commands.CanConvertSelection}"/>
                                    </Grid>
                                    <Button Content="Duplicate Selection"
                                            Classes="InspectorButton"
                                            Command="{Binding Actions.DuplicateSelectionCommand}"
                                            IsEnabled="{Binding Commands.CanDuplicateSelection}"/>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Gizmo and Snapping" IsExpanded="True">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="SectionLabel" Text="Snap and axis toggles are in the toolbar."/>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="GizmoSnapLabel" Text="{Binding Options.GizmoSnapLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="GizmoSnapSlider"
                                                Minimum="0.1"
                                                Maximum="2.0"
                                                Value="{Binding Options.GizmoSnap, Mode=TwoWay}"
                                                TickFrequency="0.1"
                                                SmallChange="0.1"
                                                LargeChange="0.5"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="GizmoRotateSnapLabel" Text="{Binding Options.GizmoRotateSnapLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="GizmoRotateSnapSlider"
                                                Minimum="1"
                                                Maximum="90"
                                                Value="{Binding Options.GizmoRotateSnap, Mode=TwoWay}"
                                                TickFrequency="5"
                                                SmallChange="1"
                                                LargeChange="10"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="GizmoScaleSnapLabel" Text="{Binding Options.GizmoScaleSnapLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="GizmoScaleSnapSlider"
                                                Minimum="0.01"
                                                Maximum="1.0"
                                                Value="{Binding Options.GizmoScaleSnap, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.01"
                                                LargeChange="0.1"/>
                                    </StackPanel>
                                    <Button Content="Transform Values..."
                                            Classes="InspectorButton"
                                            Command="{Binding Actions.TransformSelectionCommand}"
                                            IsEnabled="{Binding Commands.CanNumericTransform}"/>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Modeling Ops" IsExpanded="True">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="SectionLabel" Text="Face tools"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button x:Name="ExtrudeButton"
                                                Content="Extrude"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.ExtrudeFacesCommand}"
                                                IsEnabled="{Binding Commands.CanExtrudeFaces}"/>
                                        <Button x:Name="BevelButton"
                                                Content="Bevel"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.BevelFacesCommand}"
                                                IsEnabled="{Binding Commands.CanBevelFaces}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button x:Name="InsetButton"
                                                Content="Inset"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.InsetFacesCommand}"
                                                IsEnabled="{Binding Commands.CanInsetFaces}"/>
                                        <Button x:Name="LoopCutButton"
                                                Content="Loop Cut"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.LoopCutEdgeLoopCommand}"
                                                IsEnabled="{Binding Commands.CanLoopCutEdgeLoop}"/>
                                    </Grid>
                                    <Button x:Name="DetachFacesButton"
                                            Content="Detach Faces"
                                            Classes="InspectorButton"
                                            Command="{Binding Actions.DetachFacesCommand}"
                                            IsEnabled="{Binding Commands.CanDetachFaces}"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Options.ExtrudeDistanceLabel}" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0.01"
                                                Maximum="5.0"
                                                Value="{Binding Options.ExtrudeDistance, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.2"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Options.InsetDistanceLabel}" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0.01"
                                                Maximum="2.0"
                                                Value="{Binding Options.InsetDistance, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Options.BevelInsetLabel}" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0.0"
                                                Maximum="2.0"
                                                Value="{Binding Options.BevelInset, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Options.BevelHeightLabel}" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0.0"
                                                Maximum="2.0"
                                                Value="{Binding Options.BevelHeight, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"/>
                                    </StackPanel>
                                    <TextBlock Classes="SectionLabel" Text="Edge tools"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button x:Name="SplitEdgeButton"
                                                Content="Split Edge"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.SplitEdgeCommand}"
                                                IsEnabled="{Binding Commands.CanSplitEdge}"/>
                                        <Button x:Name="BridgeEdgesButton"
                                                Content="Bridge Edges"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.BridgeEdgesCommand}"
                                                IsEnabled="{Binding Commands.CanBridgeEdges}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button x:Name="BridgeEdgeLoopsButton"
                                                Content="Bridge Edge Loops"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.BridgeEdgeLoopsCommand}"
                                                IsEnabled="{Binding Commands.CanBridgeEdgeLoops}"/>
                                        <Button x:Name="DissolveEdgeButton"
                                                Content="Dissolve Edge"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.DissolveEdgeCommand}"
                                                IsEnabled="{Binding Commands.CanDissolveEdge}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button x:Name="CollapseEdgeButton"
                                                Content="Collapse Edge"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.CollapseEdgeCommand}"
                                                IsEnabled="{Binding Commands.CanCollapseEdge}"/>
                                        <Button x:Name="MergeVerticesButton"
                                                Content="Merge Verts"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.MergeVerticesCommand}"
                                                IsEnabled="{Binding Commands.CanMergeVertices}"/>
                                    </Grid>
                                    <TextBlock Classes="SectionLabel" Text="Face cleanup"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button x:Name="DissolveFacesButton"
                                                Content="Dissolve Faces"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.DissolveFacesCommand}"
                                                IsEnabled="{Binding Commands.CanDissolveFaces}"/>
                                        <Button x:Name="WeldVerticesButton"
                                                Content="Weld Verts"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.WeldVerticesCommand}"/>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Options.WeldToleranceLabel}" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0.001"
                                                Maximum="0.1"
                                                Value="{Binding Options.WeldTolerance, Mode=TwoWay}"
                                                TickFrequency="0.005"
                                                SmallChange="0.005"
                                                LargeChange="0.02"/>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button x:Name="CleanupButton"
                                                Content="Cleanup"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.CleanupMeshCommand}"
                                                IsEnabled="{Binding Commands.CanCleanupMesh}"/>
                                        <Button x:Name="SmoothButton"
                                                Content="Smooth"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.SmoothMeshCommand}"
                                                IsEnabled="{Binding Commands.CanSmoothMesh}"/>
                                    </Grid>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Simplify" IsExpanded="False">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="SectionLabel" Text="Simplify selection or entire mesh"/>
                                    <Button x:Name="SimplifyButton"
                                            Content="Simplify Mesh"
                                            Classes="InspectorButton"
                                            Command="{Binding Actions.SimplifyMeshCommand}"
                                            IsEnabled="{Binding Commands.CanSimplifyMesh}"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="SimplifyRatioLabel" Text="{Binding Options.SimplifyRatioLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="SimplifyRatioSlider"
                                                Minimum="0.1"
                                                Maximum="1.0"
                                                Value="{Binding Options.SimplifyRatio, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Smooth" IsExpanded="False">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="SectionLabel" Text="Smooth sculpting controls"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="SmoothIterationsLabel" Text="{Binding Options.SmoothIterationsLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="SmoothIterationsSlider"
                                                Minimum="1"
                                                Maximum="8"
                                                Value="{Binding Options.SmoothIterations, Mode=TwoWay}"
                                                TickFrequency="1"
                                                SmallChange="1"
                                                LargeChange="1"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="SmoothStrengthLabel" Text="{Binding Options.SmoothStrengthLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="SmoothStrengthSlider"
                                                Minimum="0.1"
                                                Maximum="1.0"
                                                Value="{Binding Options.SmoothStrength, Mode=TwoWay}"
                                                TickFrequency="0.1"
                                                SmallChange="0.1"
                                                LargeChange="0.1"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Nudge" IsExpanded="False">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="SectionLabel" Text="Step selection by the current nudge increment"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="+X" Classes="InspectorButton" Command="{Binding Actions.NudgePosXCommand}"/>
                                        <Button Content="-X" Classes="InspectorButton" Command="{Binding Actions.NudgeNegXCommand}"/>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Options.NudgeStepLabel}" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0.01"
                                                Maximum="1.0"
                                                Value="{Binding Options.NudgeStep, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Proportional Editing" IsExpanded="False">
                                <StackPanel Spacing="8">
                                    <CheckBox x:Name="ProportionalToggle" Content="Enable" IsChecked="{Binding Options.ProportionalEnabled, Mode=TwoWay}" Foreground="#E8EEF5"/>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <TextBlock Classes="SectionLabel" Text="Falloff" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="ProportionalFalloffCombo" Grid.Column="1" Classes="InspectorCombo" Width="140" SelectedIndex="{Binding Options.ProportionalFalloffIndex, Mode=TwoWay}">
                                            <ComboBoxItem Content="Linear"/>
                                            <ComboBoxItem Content="Smooth"/>
                                            <ComboBoxItem Content="Sharp"/>
                                            <ComboBoxItem Content="Root"/>
                                        </ComboBox>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="ProportionalRadiusLabel" Text="{Binding Options.ProportionalRadiusLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="ProportionalRadiusSlider"
                                                Minimum="0.2"
                                                Maximum="10.0"
                                                Value="{Binding Options.ProportionalRadius, Mode=TwoWay}"
                                                TickFrequency="0.2"
                                                SmallChange="0.2"
                                                LargeChange="1.0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="UV Tools" IsExpanded="False">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button x:Name="PlanarUvButton"
                                                Content="Planar UV"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.PlanarUvCommand}"
                                                IsEnabled="{Binding Commands.CanPlanarUv}"/>
                                        <Button x:Name="BoxUvButton"
                                                Content="Box UV"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.BoxUvCommand}"
                                                IsEnabled="{Binding Commands.CanBoxUv}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button x:Name="UnwrapUvButton"
                                                Content="Unwrap"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.UnwrapUvCommand}"
                                                IsEnabled="{Binding Commands.CanUnwrapUv}"/>
                                        <Button x:Name="PackUvButton"
                                                Content="Pack"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.PackUvCommand}"
                                                IsEnabled="{Binding Commands.CanPackUv}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <TextBlock Classes="SectionLabel" Text="Unwrap method" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="UvUnwrapMethodCombo"
                                                  Grid.Column="1"
                                                  Classes="InspectorCombo"
                                                  Width="140"
                                                  SelectedIndex="{Binding Options.UvUnwrapMethodIndex, Mode=TwoWay}">
                                            <ComboBoxItem Content="Planar"/>
                                            <ComboBoxItem Content="LSCM"/>
                                            <ComboBoxItem Content="ABF"/>
                                        </ComboBox>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                        <Button x:Name="MarkUvSeamButton"
                                                Content="Mark Seam"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.MarkUvSeamsCommand}"
                                                IsEnabled="{Binding Commands.CanMarkUvSeams}"/>
                                        <Button x:Name="ClearUvSeamButton"
                                                Content="Clear Seam"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.ClearUvSeamsCommand}"
                                                IsEnabled="{Binding Commands.CanClearUvSeams}"/>
                                        <Button x:Name="ClearAllUvSeamButton"
                                                Content="Clear All"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.ClearAllUvSeamsCommand}"
                                                IsEnabled="{Binding Commands.CanClearAllUvSeams}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button x:Name="SelectUvIslandButton"
                                                Content="Select Island"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.SelectUvIslandCommand}"
                                                IsEnabled="{Binding Commands.CanSelectUvIsland}"/>
                                        <CheckBox x:Name="UvShowSeamsToggle"
                                                  Content="Show seams"
                                                  Foreground="#E8EEF5"
                                                  IsChecked="{Binding Options.UvShowSeams, Mode=TwoWay}"/>
                                    </Grid>
                                    <CheckBox x:Name="UvShowIslandsToggle"
                                              Content="Show islands"
                                              Foreground="#E8EEF5"
                                              IsChecked="{Binding Options.UvShowIslands, Mode=TwoWay}"/>
                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                        <Button x:Name="NormalizeUvButton"
                                                Content="Normalize"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.NormalizeUvCommand}"
                                                IsEnabled="{Binding Commands.CanNormalizeUv}"/>
                                        <Button x:Name="FlipUButton"
                                                Content="Flip U"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.FlipUCommand}"
                                                IsEnabled="{Binding Commands.CanFlipU}"/>
                                        <Button x:Name="FlipVButton"
                                                Content="Flip V"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.FlipVCommand}"
                                                IsEnabled="{Binding Commands.CanFlipV}"/>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="UvScaleLabel" Text="{Binding Options.UvScaleLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="UvScaleSlider"
                                                Minimum="0.1"
                                                Maximum="4.0"
                                                Value="{Binding Options.UvScale, Mode=TwoWay}"
                                                TickFrequency="0.1"
                                                SmallChange="0.1"
                                                LargeChange="0.5"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="UvUnwrapAngleLabel" Text="{Binding Options.UvUnwrapAngleLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="UvUnwrapAngleSlider"
                                                Minimum="5"
                                                Maximum="180"
                                                Value="{Binding Options.UvUnwrapAngle, Mode=TwoWay}"
                                                TickFrequency="5"
                                                SmallChange="1"
                                                LargeChange="10"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="UvPackPaddingLabel" Text="{Binding Options.UvPackPaddingLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="UvPackPaddingSlider"
                                                Minimum="0.0"
                                                Maximum="0.1"
                                                Value="{Binding Options.UvPackPadding, Mode=TwoWay}"
                                                TickFrequency="0.01"
                                                SmallChange="0.005"
                                                LargeChange="0.02"/>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <CheckBox x:Name="UvPackRotateToggle"
                                                  Content="Rotate islands"
                                                  Foreground="#E8EEF5"
                                                  IsChecked="{Binding Options.UvPackRotate, Mode=TwoWay}"/>
                                        <CheckBox x:Name="UvPackUseGroupsToggle"
                                                  Content="Use groups"
                                                  Foreground="#E8EEF5"
                                                  IsChecked="{Binding Options.UvPackUseGroups, Mode=TwoWay}"/>
                                    </Grid>
                                    <CheckBox x:Name="UvPackTexelToggle"
                                              Content="Preserve texel density"
                                              Foreground="#E8EEF5"
                                              IsChecked="{Binding Options.UvPackPreserveTexelDensity, Mode=TwoWay}"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="UvPackTexelDensityLabel"
                                                   Text="{Binding Options.UvPackTexelDensityLabel}"
                                                   Foreground="#A3AFBD"
                                                   IsEnabled="{Binding Options.UvPackPreserveTexelDensity}"/>
                                        <Slider x:Name="UvPackTexelDensitySlider"
                                                Minimum="0.1"
                                                Maximum="10.0"
                                                Value="{Binding Options.UvPackTexelDensity, Mode=TwoWay}"
                                                IsEnabled="{Binding Options.UvPackPreserveTexelDensity}"
                                                TickFrequency="0.1"
                                                SmallChange="0.1"
                                                LargeChange="1.0"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="UvGroupLabel" Text="UV group ID" Foreground="#A3AFBD"/>
                                        <Slider x:Name="UvGroupSlider"
                                                Minimum="0"
                                                Maximum="16"
                                                IsSnapToTickEnabled="True"
                                                TickFrequency="1"
                                                Value="{Binding Options.UvGroupId, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button x:Name="AssignUvGroupButton"
                                                Content="Assign Group"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.AssignUvGroupCommand}"
                                                CommandParameter="{Binding Options.UvGroupId}"
                                                IsEnabled="{Binding Commands.CanAssignUvGroup}"/>
                                        <Button x:Name="ClearUvGroupButton"
                                                Content="Clear Group"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.ClearUvGroupCommand}"
                                                IsEnabled="{Binding Commands.CanClearUvGroup}"/>
                                    </Grid>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Classes="CommandTab" ToolTip.Tip="Hierarchy">
                    <TabItem.Header>
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <Viewbox Width="18" Height="18">
                                <Path Classes="CommandTabIcon" Data="M2,3 H10 M6,3 V9 M2,9 H10"/>
                            </Viewbox>
                            <TextBlock Classes="CommandTabLabel" Text="Hierarchy"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.IsScrollChainingEnabled="False"
                                  Padding="10">
                        <StackPanel Spacing="8">
                            <Expander Classes="InspectorRollout" Header="Scene Hierarchy" IsExpanded="True">
                                <TreeView x:Name="HierarchyTree"
                                          ItemsSource="{Binding Hierarchy.Items}"
                                          SelectedItem="{Binding Hierarchy.SelectedItem, Mode=TwoWay}"
                                          BorderThickness="0">
                                    <TreeView.ItemTemplate>
                                        <TreeDataTemplate DataType="{x:Type local:SceneNodeItem}"
                                                          ItemsSource="{Binding Children}">
                                            <TextBlock Text="{Binding Name}" Foreground="#E8EEF5"/>
                                        </TreeDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Selection" IsExpanded="True">
                                <StackPanel Spacing="6">
                                    <TextBlock x:Name="HierarchySelectionLabel" Text="{Binding Hierarchy.SelectionLabel}" Foreground="#A3AFBD"/>
                                    <TextBlock x:Name="HierarchyPositionLabel" Text="{Binding Hierarchy.PositionLabel}" Foreground="#A3AFBD"/>
                                    <TextBlock x:Name="HierarchyRotationLabel" Text="{Binding Hierarchy.RotationLabel}" Foreground="#A3AFBD"/>
                                    <TextBlock x:Name="HierarchyScaleLabel" Text="{Binding Hierarchy.ScaleLabel}" Foreground="#A3AFBD"/>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Pivot and Transforms" IsExpanded="True">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="SectionLabel" Text="Pivot tools affect the selected object."/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button x:Name="CenterPivotButton"
                                                Content="Center Pivot"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.CenterPivotCommand}"
                                                IsEnabled="{Binding Hierarchy.CanCenterPivot}"/>
                                        <Button x:Name="ResetTransformButton"
                                                Content="Reset Transform"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.ResetTransformCommand}"
                                                IsEnabled="{Binding Hierarchy.CanResetTransform}"/>
                                    </Grid>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Constraints" IsExpanded="False">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding Constraints.SelectionLabel}" Foreground="#A3AFBD"/>
                                    <ComboBox x:Name="ConstraintTargetCombo"
                                              Classes="InspectorCombo"
                                              ItemsSource="{Binding Constraints.Targets}"
                                              SelectedItem="{Binding Constraints.SelectedTarget, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:SceneNodeItem}">
                                                <TextBlock Text="{Binding Name}" Foreground="#E8EEF5"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <ComboBox x:Name="ConstraintTypeCombo"
                                              Classes="InspectorCombo"
                                              SelectedIndex="{Binding Constraints.ConstraintTypeIndex, Mode=TwoWay}">
                                        <ComboBoxItem Content="None"/>
                                        <ComboBoxItem Content="Parent"/>
                                        <ComboBoxItem Content="Look At"/>
                                    </ComboBox>
                                    <CheckBox x:Name="ConstraintMaintainOffsetToggle"
                                              Content="Maintain offset"
                                              Foreground="#E8EEF5"
                                              IsChecked="{Binding Constraints.MaintainOffset, Mode=TwoWay}"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="ConstraintWeightLabel" Text="{Binding Constraints.WeightLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="ConstraintWeightSlider"
                                                Minimum="0"
                                                Maximum="1"
                                                Value="{Binding Constraints.Weight, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"/>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button x:Name="ApplyConstraintButton"
                                                Content="Apply"
                                                Classes="InspectorButton"
                                                Command="{Binding Constraints.ApplyConstraintCommand}"/>
                                        <Button x:Name="ClearConstraintButton"
                                                Content="Clear"
                                                Classes="InspectorButton"
                                                Command="{Binding Constraints.ClearConstraintCommand}"/>
                                    </Grid>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Classes="CommandTab" ToolTip.Tip="Motion">
                    <TabItem.Header>
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <Viewbox Width="18" Height="18">
                                <Path Classes="CommandTabIcon" Data="M2,2 L10,6 L2,10 Z"/>
                            </Viewbox>
                            <TextBlock Classes="CommandTabLabel" Text="Motion"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.IsScrollChainingEnabled="False"
                                  Padding="10">
                        <StackPanel Spacing="8">
                            <Expander Classes="InspectorRollout" Header="Playback" IsExpanded="True">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="AnimationStatusLabel" Text="{Binding Motion.StatusLabel}" Foreground="#A3AFBD"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <ToggleButton x:Name="AnimationPlayToggle"
                                                      Content="{Binding Motion.PlayLabel}"
                                                      Classes="InspectorButton"
                                                      IsEnabled="{Binding Motion.CanPlay}"
                                                      IsChecked="{Binding Motion.IsPlaying}"/>
                                        <Button x:Name="AnimationResetButton"
                                                Content="Reset"
                                                Classes="InspectorButton"
                                                Command="{Binding Actions.AnimationResetCommand}"
                                                IsEnabled="{Binding Motion.CanReset}"/>
                                    </Grid>
                                    <CheckBox x:Name="AnimationLoopToggle"
                                              Content="Loop"
                                              Foreground="#E8EEF5"
                                              IsEnabled="{Binding Motion.CanLoop}"
                                              IsChecked="{Binding Motion.Loop}"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="AnimationSpeedLabel" Text="{Binding Motion.SpeedLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="AnimationSpeedSlider"
                                                Minimum="0.1"
                                                Maximum="2.0"
                                                Value="{Binding Motion.Speed}"
                                                TickFrequency="0.1"
                                                SmallChange="0.1"
                                                LargeChange="0.25"
                                                IsEnabled="{Binding Motion.CanAdjustSpeed}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Timeline" IsExpanded="True">
                                <StackPanel Spacing="6">
                                    <TextBlock x:Name="AnimationTimeLabel" Text="{Binding Motion.TimeLabel}" Foreground="#A3AFBD"/>
                                    <Slider x:Name="AnimationTimeSlider"
                                            Minimum="0"
                                            Maximum="{Binding Motion.TimeMax}"
                                            Value="{Binding Motion.Time}"
                                            TickFrequency="0.1"
                                            SmallChange="0.1"
                                            LargeChange="0.25"
                                            IsEnabled="{Binding Motion.CanScrub}"/>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Clips" IsExpanded="True">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding Motion.Editor.ClipSummary}" Foreground="#A3AFBD"/>
                                    <ComboBox Classes="InspectorCombo"
                                              ItemsSource="{Binding Motion.Editor.Clips}"
                                              SelectedItem="{Binding Motion.Editor.SelectedClip, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AnimationClipItem}">
                                                <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                        <Button Content="New"
                                                Classes="InspectorButton"
                                                Command="{Binding Motion.Editor.CreateClipCommand}"/>
                                        <Button Content="Duplicate"
                                                Classes="InspectorButton"
                                                Command="{Binding Motion.Editor.DuplicateClipCommand}"
                                                IsEnabled="{Binding Motion.Editor.CanEditClip}"/>
                                        <Button Content="Delete"
                                                Classes="InspectorButton"
                                                Command="{Binding Motion.Editor.DeleteClipCommand}"
                                                IsEnabled="{Binding Motion.Editor.CanEditClip}"/>
                                    </Grid>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Tracks" IsExpanded="False">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding Motion.Editor.TrackSummary}" Foreground="#A3AFBD"/>
                                    <ComboBox Classes="InspectorCombo"
                                              ItemsSource="{Binding Motion.Editor.Tracks}"
                                              SelectedItem="{Binding Motion.Editor.SelectedTrack, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AnimationTrackItem}">
                                                <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Add from Selection"
                                                Classes="InspectorButton"
                                                Command="{Binding Motion.Editor.AddTrackCommand}"
                                                IsEnabled="{Binding Motion.Editor.CanEditClip}"/>
                                        <Button Content="Remove"
                                                Classes="InspectorButton"
                                                Command="{Binding Motion.Editor.RemoveTrackCommand}"
                                                IsEnabled="{Binding Motion.Editor.CanEditTrack}"/>
                                    </Grid>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Keyframes" IsExpanded="False">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding Motion.Editor.KeySummary}" Foreground="#A3AFBD"/>
                                    <ComboBox Classes="InspectorCombo"
                                              ItemsSource="{Binding Motion.Editor.Channels}"
                                              SelectedItem="{Binding Motion.Editor.SelectedChannel, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AnimationKeyframeChannel}">
                                                <TextBlock Text="{Binding}" Foreground="#E8EEF5"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <ListBox ItemsSource="{Binding Motion.Editor.Keyframes}"
                                             SelectedItem="{Binding Motion.Editor.SelectedKeyframe, Mode=TwoWay}"
                                             MaxHeight="120">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AnimationKeyframeItem}">
                                                <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                        <Button Content="Capture"
                                                Classes="InspectorButton"
                                                Command="{Binding Motion.SetKeyCommand}"
                                                IsEnabled="{Binding Motion.CanSetKey}"/>
                                        <Button Content="Delete"
                                                Classes="InspectorButton"
                                                Command="{Binding Motion.Editor.DeleteKeyCommand}"
                                                IsEnabled="{Binding Motion.Editor.CanEditKey}"/>
                                        <Button Content="Jump"
                                                Classes="InspectorButton"
                                                Command="{Binding Motion.Editor.JumpToKeyCommand}"
                                                IsEnabled="{Binding Motion.Editor.CanEditKey}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Prev"
                                                Classes="InspectorButton"
                                                Command="{Binding Motion.Editor.PrevKeyCommand}"
                                                IsEnabled="{Binding Motion.Editor.HasSelectedTrack}"/>
                                        <Button Content="Next"
                                                Classes="InspectorButton"
                                                Command="{Binding Motion.Editor.NextKeyCommand}"
                                                IsEnabled="{Binding Motion.Editor.HasSelectedTrack}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="4">
                                        <TextBlock Text="Time" Foreground="#E8EEF5"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Motion.Editor.KeyTimeText, Mode=TwoWay}"
                                                 IsEnabled="{Binding Motion.Editor.CanEditKey}"/>
                                        <TextBlock Grid.Row="1" Text="X" Foreground="#E8EEF5"/>
                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                 Text="{Binding Motion.Editor.KeyValueXText, Mode=TwoWay}"
                                                 IsEnabled="{Binding Motion.Editor.CanEditKey}"/>
                                        <TextBlock Grid.Row="2" Text="Y" Foreground="#E8EEF5"/>
                                        <TextBox Grid.Row="2" Grid.Column="1"
                                                 Text="{Binding Motion.Editor.KeyValueYText, Mode=TwoWay}"
                                                 IsEnabled="{Binding Motion.Editor.CanEditKey}"/>
                                        <TextBlock Grid.Row="3" Text="Z" Foreground="#E8EEF5"/>
                                        <TextBox Grid.Row="3" Grid.Column="1"
                                                 Text="{Binding Motion.Editor.KeyValueZText, Mode=TwoWay}"
                                                 IsEnabled="{Binding Motion.Editor.CanEditKey}"/>
                                    </Grid>
                                    <Button Content="Apply Key"
                                            Classes="InspectorButton"
                                            Command="{Binding Motion.Editor.ApplyKeyEditsCommand}"
                                            IsEnabled="{Binding Motion.Editor.CanEditKey}"/>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Curve Editor" IsExpanded="False">
                                <Border Background="#20252B" BorderBrush="#1F2328" BorderThickness="1" Padding="6">
                                    <controls:AnimationCurveEditorControl Height="160"
                                                                          Series="{Binding Motion.Editor.CurveSeries}"
                                                                          Duration="{Binding Motion.Editor.SelectedClipDuration}"
                                                                          PlayheadTime="{Binding Motion.Time}"
                                                                          SelectedTime="{Binding Motion.Editor.SelectedKeyTime}"/>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Classes="CommandTab" ToolTip.Tip="Utilities">
                    <TabItem.Header>
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <Viewbox Width="18" Height="18">
                                <Path Classes="CommandTabIcon" Data="M2,6 H10 M6,2 V10"/>
                            </Viewbox>
                            <TextBlock Classes="CommandTabLabel" Text="Utilities"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.IsScrollChainingEnabled="False"
                                  Padding="10">
                        <StackPanel Spacing="8">
                            <Expander Classes="InspectorRollout" Header="Viewport" IsExpanded="True">
                                <StackPanel Spacing="8">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="SectionTitle" Text="Viewport effects"/>
                                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                                            <CheckBox x:Name="ShadowToggle" Grid.Row="0" Grid.Column="0" Content="Shadows" IsChecked="{Binding Options.ShadowEnabled, Mode=TwoWay}" Foreground="#E8EEF5"/>
                                            <CheckBox x:Name="SsaoToggle" Grid.Row="0" Grid.Column="1" Content="SSAO" IsChecked="{Binding Options.SsaoEnabled, Mode=TwoWay}" Foreground="#E8EEF5"/>
                                            <CheckBox x:Name="PickDebugToggle" Grid.Row="1" Grid.Column="0" Content="Pick debug" IsChecked="{Binding Options.PickDebugEnabled, Mode=TwoWay}" Foreground="#E8EEF5"/>
                                            <CheckBox x:Name="StatsToggle" Grid.Row="1" Grid.Column="1" Content="Show stats" IsChecked="{Binding Options.ShowStats, Mode=TwoWay}" Foreground="#E8EEF5"/>
                                        </Grid>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <TextBlock Classes="SectionLabel" Text="Pick accel" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="PickAccelCombo" Grid.Column="1" Classes="InspectorCombo" Width="160" SelectedIndex="{Binding Options.PickAccelIndex, Mode=TwoWay}">
                                            <ComboBoxItem Content="Auto"/>
                                            <ComboBoxItem Content="BVH"/>
                                            <ComboBoxItem Content="Uniform grid"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Rendering" IsExpanded="False">
                                <StackPanel Spacing="10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="SectionTitle" Text="Surface options"/>
                                        <CheckBox Content="Backface culling"
                                                  IsChecked="{Binding Options.BackfaceCullingEnabled, Mode=TwoWay}"
                                                  Foreground="#E8EEF5"/>
                                    </StackPanel>
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="SectionTitle" Text="Environment lighting"/>
                                        <CheckBox Content="Image based lighting"
                                                  IsChecked="{Binding Options.ImageBasedLightingEnabled, Mode=TwoWay}"
                                                  Foreground="#E8EEF5"/>
                                        <StackPanel Spacing="4" IsEnabled="{Binding Options.ImageBasedLightingEnabled}">
                                            <TextBlock Text="{Binding Options.EnvironmentIntensityLabel}" Foreground="#A3AFBD"/>
                                            <Slider Minimum="0"
                                                    Maximum="2"
                                                    Value="{Binding Options.EnvironmentIntensity, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.1"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="SectionTitle" Text="Shadow tuning"/>
                                        <CheckBox Content="Enable shadows"
                                                  IsChecked="{Binding Options.ShadowEnabled, Mode=TwoWay}"
                                                  Foreground="#E8EEF5"/>
                                        <StackPanel Spacing="6" IsEnabled="{Binding Options.ShadowEnabled}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Options.ShadowMapSizeLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="64"
                                                        Maximum="2048"
                                                        Value="{Binding Options.ShadowMapSize, Mode=TwoWay}"
                                                        TickFrequency="128"
                                                        SmallChange="64"
                                                        LargeChange="256"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Options.ShadowBiasLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="0.01"
                                                        Value="{Binding Options.ShadowBias, Mode=TwoWay}"
                                                        TickFrequency="0.0005"
                                                        SmallChange="0.0005"
                                                        LargeChange="0.001"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Options.ShadowNormalBiasLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="0.01"
                                                        Value="{Binding Options.ShadowNormalBias, Mode=TwoWay}"
                                                        TickFrequency="0.0005"
                                                        SmallChange="0.0005"
                                                        LargeChange="0.001"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Options.ShadowStrengthLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0.1"
                                                        Maximum="1.0"
                                                        Value="{Binding Options.ShadowStrength, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Options.ShadowPcfRadiusLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="4"
                                                        Value="{Binding Options.ShadowPcfRadius, Mode=TwoWay}"
                                                        TickFrequency="1"
                                                        SmallChange="1"
                                                        LargeChange="1"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="SectionTitle" Text="SSAO tuning"/>
                                        <CheckBox Content="Enable SSAO"
                                                  IsChecked="{Binding Options.SsaoEnabled, Mode=TwoWay}"
                                                  Foreground="#E8EEF5"/>
                                        <StackPanel Spacing="6" IsEnabled="{Binding Options.SsaoEnabled}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Options.SsaoRadiusLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="1"
                                                        Maximum="24"
                                                        Value="{Binding Options.SsaoRadius, Mode=TwoWay}"
                                                        TickFrequency="1"
                                                        SmallChange="1"
                                                        LargeChange="2"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Options.SsaoIntensityLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Options.SsaoIntensity, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Options.SsaoDepthBiasLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="0.01"
                                                        Value="{Binding Options.SsaoDepthBias, Mode=TwoWay}"
                                                        TickFrequency="0.0005"
                                                        SmallChange="0.0005"
                                                        LargeChange="0.001"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Options.SsaoSampleCountLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="1"
                                                        Maximum="16"
                                                        Value="{Binding Options.SsaoSampleCount, Mode=TwoWay}"
                                                        TickFrequency="1"
                                                        SmallChange="1"
                                                        LargeChange="1"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Post FX" IsExpanded="False">
                                <StackPanel Spacing="8">
                                    <CheckBox Content="Enable post processing"
                                              IsChecked="{Binding Options.PostProcessingEnabled, Mode=TwoWay}"
                                              Foreground="#E8EEF5"/>
                                    <StackPanel Spacing="8" IsEnabled="{Binding Options.PostProcessingEnabled}">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <TextBlock Classes="SectionLabel" Text="Tone mapping" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Column="1"
                                                      Classes="InspectorCombo"
                                                      Width="180"
                                                      SelectedIndex="{Binding Options.ToneMappingIndex, Mode=TwoWay}">
                                                <ComboBoxItem Content="None"/>
                                                <ComboBoxItem Content="Reinhard"/>
                                                <ComboBoxItem Content="ACES"/>
                                            </ComboBox>
                                        </Grid>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Options.PostExposureLabel}" Foreground="#A3AFBD"/>
                                            <Slider Minimum="0"
                                                    Maximum="3"
                                                    Value="{Binding Options.PostExposure, Mode=TwoWay}"
                                                    TickFrequency="0.1"
                                                    SmallChange="0.1"
                                                    LargeChange="0.2"/>
                                        </StackPanel>
                                        <CheckBox Content="Bloom"
                                                  IsChecked="{Binding Options.BloomEnabled, Mode=TwoWay}"
                                                  Foreground="#E8EEF5"/>
                                        <StackPanel Spacing="6" IsEnabled="{Binding Options.BloomEnabled}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Options.BloomThresholdLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Options.BloomThreshold, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Options.BloomIntensityLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="2"
                                                        Value="{Binding Options.BloomIntensity, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Options.BloomRadiusLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="16"
                                                        Value="{Binding Options.BloomRadius, Mode=TwoWay}"
                                                        TickFrequency="1"
                                                        SmallChange="1"
                                                        LargeChange="2"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <CheckBox Content="FXAA"
                                                  IsChecked="{Binding Options.FxaaEnabled, Mode=TwoWay}"
                                                  Foreground="#E8EEF5"/>
                                        <StackPanel Spacing="6" IsEnabled="{Binding Options.FxaaEnabled}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Options.FxaaEdgeThresholdLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Options.FxaaEdgeThreshold, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Options.FxaaEdgeThresholdMinLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="0.5"
                                                        Value="{Binding Options.FxaaEdgeThresholdMin, Mode=TwoWay}"
                                                        TickFrequency="0.02"
                                                        SmallChange="0.02"
                                                        LargeChange="0.05"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Options.FxaaSubpixelBlendLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Options.FxaaSubpixelBlend, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Quality" IsExpanded="False">
                                <StackPanel Spacing="6">
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="RenderScaleLabel" Text="{Binding Options.RenderScaleLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="RenderScaleSlider"
                                                Minimum="0.25"
                                                Maximum="1"
                                                Value="{Binding Options.RenderScale, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="RenderWorkerCountLabel" Text="{Binding Options.RenderWorkerCountLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="RenderWorkerCountSlider"
                                                Minimum="1"
                                                Maximum="64"
                                                Value="{Binding Options.RenderWorkerCount, Mode=TwoWay}"
                                                IsSnapToTickEnabled="True"
                                                TickFrequency="1"
                                                SmallChange="1"
                                                LargeChange="4"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="MeshPrecisionLabel" Text="{Binding Options.MeshPrecisionLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="MeshPrecisionSlider"
                                                Minimum="4"
                                                Maximum="64"
                                                Value="{Binding Options.MeshPrecision, Mode=TwoWay}"
                                                TickFrequency="4"
                                                SmallChange="1"
                                                LargeChange="4"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="SubdivisionLabel" Text="{Binding Options.SubdivisionLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="SubdivisionSlider"
                                                Minimum="4"
                                                Maximum="256"
                                                Value="{Binding Options.Subdivision, Mode=TwoWay}"
                                                TickFrequency="8"
                                                SmallChange="1"
                                                LargeChange="8"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Material Editor" IsExpanded="False">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding Material.SelectionLabel}" Foreground="#A3AFBD"/>
                                    <Border Background="#20252B" BorderBrush="#1F2328" BorderThickness="1" CornerRadius="2" Padding="6">
                                        <controls:MaterialPreviewControl Height="120"
                                                                          Material="{Binding Material.SelectedMaterial}"
                                                                          Stamp="{Binding Material.PreviewStamp}"/>
                                    </Border>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <TextBlock Classes="SectionLabel" Text="Shading model" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1"
                                                  Classes="InspectorCombo"
                                                  SelectedIndex="{Binding Material.ShadingModelIndex, Mode=TwoWay}">
                                            <ComboBoxItem Content="Phong"/>
                                            <ComboBoxItem Content="PBR (Metal/Rough)"/>
                                        </ComboBox>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <CheckBox Content="Vertex color"
                                                  Foreground="#E8EEF5"
                                                  IsChecked="{Binding Material.UseVertexColor, Mode=TwoWay}"/>
                                        <CheckBox Content="Double sided"
                                                  Foreground="#E8EEF5"
                                                  IsChecked="{Binding Material.DoubleSided, Mode=TwoWay}"/>
                                    </Grid>
                                    <TextBlock Classes="SectionTitle" Text="PBR Inputs"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Material.BaseColorLabel}" Foreground="#A3AFBD"/>
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="4">
                                            <TextBlock Text="R" Foreground="#E8EEF5"/>
                                            <Slider Grid.Column="1"
                                                    Minimum="0"
                                                    Maximum="1"
                                                    Value="{Binding Material.BaseColorR, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.1"/>
                                            <TextBlock Grid.Row="1" Text="G" Foreground="#E8EEF5"/>
                                            <Slider Grid.Row="1" Grid.Column="1"
                                                    Minimum="0"
                                                    Maximum="1"
                                                    Value="{Binding Material.BaseColorG, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.1"/>
                                            <TextBlock Grid.Row="2" Text="B" Foreground="#E8EEF5"/>
                                            <Slider Grid.Row="2" Grid.Column="1"
                                                    Minimum="0"
                                                    Maximum="1"
                                                    Value="{Binding Material.BaseColorB, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.1"/>
                                        </Grid>
                                        <ComboBox x:Name="BaseColorSourceCombo"
                                                  Classes="InspectorCombo"
                                                  ItemsSource="{Binding Material.BaseColorSources}"
                                                  SelectedIndex="{Binding Material.BaseColorSourceIndex, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:ShaderSourceOption}">
                                                    <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Material.MetallicLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="MetallicSlider"
                                                Minimum="0"
                                                Maximum="1"
                                                Value="{Binding Material.Metallic, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"/>
                                        <ComboBox x:Name="MetallicSourceCombo"
                                                  Classes="InspectorCombo"
                                                  ItemsSource="{Binding Material.MetallicSources}"
                                                  SelectedIndex="{Binding Material.MetallicSourceIndex, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:ShaderSourceOption}">
                                                    <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Material.RoughnessLabel}" Foreground="#A3AFBD"/>
                                        <Slider x:Name="RoughnessSlider"
                                                Minimum="0"
                                                Maximum="1"
                                                Value="{Binding Material.Roughness, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"/>
                                        <ComboBox x:Name="RoughnessSourceCombo"
                                                  Classes="InspectorCombo"
                                                  ItemsSource="{Binding Material.RoughnessSources}"
                                                  SelectedIndex="{Binding Material.RoughnessSourceIndex, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:ShaderSourceOption}">
                                                    <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Material.EmissiveLabel}" Foreground="#A3AFBD"/>
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="4">
                                            <TextBlock Text="R" Foreground="#E8EEF5"/>
                                            <Slider Grid.Column="1"
                                                    Minimum="0"
                                                    Maximum="1"
                                                    Value="{Binding Material.EmissiveR, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.1"/>
                                            <TextBlock Grid.Row="1" Text="G" Foreground="#E8EEF5"/>
                                            <Slider Grid.Row="1" Grid.Column="1"
                                                    Minimum="0"
                                                    Maximum="1"
                                                    Value="{Binding Material.EmissiveG, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.1"/>
                                            <TextBlock Grid.Row="2" Text="B" Foreground="#E8EEF5"/>
                                            <Slider Grid.Row="2" Grid.Column="1"
                                                    Minimum="0"
                                                    Maximum="1"
                                                    Value="{Binding Material.EmissiveB, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.1"/>
                                        </Grid>
                                        <ComboBox x:Name="EmissiveSourceCombo"
                                                  Classes="InspectorCombo"
                                                  ItemsSource="{Binding Material.EmissiveSources}"
                                                  SelectedIndex="{Binding Material.EmissiveSourceIndex, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:ShaderSourceOption}">
                                                    <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <Expander Classes="InspectorRollout" Header="Texture Slots" IsExpanded="False">
                                        <StackPanel Spacing="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="SectionLabel" Text="Base color"/>
                                                <ComboBox Classes="InspectorCombo"
                                                          ItemsSource="{Binding Material.TextureSlotOptions}"
                                                          SelectedItem="{Binding Material.BaseColorTextureSlot, Mode=TwoWay}"
                                                          IsEnabled="{Binding Material.IsBaseColorTextureConstant}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:TextureSlotOption}">
                                                            <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <ComboBox Classes="InspectorCombo"
                                                          ItemsSource="{Binding Material.TextureSources}"
                                                          SelectedIndex="{Binding Material.BaseColorTextureSourceIndex, Mode=TwoWay}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:ShaderSourceOption}">
                                                            <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBlock Text="{Binding Material.BaseColorTextureStrengthLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Material.BaseColorTextureStrength, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        IsEnabled="{Binding Material.IsBaseColorTextureConstant}"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="SectionLabel" Text="Metallic/Roughness"/>
                                                <ComboBox Classes="InspectorCombo"
                                                          ItemsSource="{Binding Material.TextureSlotOptions}"
                                                          SelectedItem="{Binding Material.MetallicRoughnessTextureSlot, Mode=TwoWay}"
                                                          IsEnabled="{Binding Material.IsMetallicRoughnessTextureConstant}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:TextureSlotOption}">
                                                            <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <ComboBox Classes="InspectorCombo"
                                                          ItemsSource="{Binding Material.TextureSources}"
                                                          SelectedIndex="{Binding Material.MetallicRoughnessTextureSourceIndex, Mode=TwoWay}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:ShaderSourceOption}">
                                                            <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBlock Text="{Binding Material.MetallicRoughnessTextureStrengthLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Material.MetallicRoughnessTextureStrength, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        IsEnabled="{Binding Material.IsMetallicRoughnessTextureConstant}"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="SectionLabel" Text="Normal"/>
                                                <ComboBox Classes="InspectorCombo"
                                                          ItemsSource="{Binding Material.TextureSlotOptions}"
                                                          SelectedItem="{Binding Material.NormalTextureSlot, Mode=TwoWay}"
                                                          IsEnabled="{Binding Material.IsNormalTextureConstant}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:TextureSlotOption}">
                                                            <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <ComboBox Classes="InspectorCombo"
                                                          ItemsSource="{Binding Material.TextureSources}"
                                                          SelectedIndex="{Binding Material.NormalTextureSourceIndex, Mode=TwoWay}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:ShaderSourceOption}">
                                                            <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBlock Text="{Binding Material.NormalStrengthLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="4"
                                                        Value="{Binding Material.NormalStrength, Mode=TwoWay}"
                                                        TickFrequency="0.1"
                                                        SmallChange="0.1"
                                                        LargeChange="0.5"
                                                        IsEnabled="{Binding Material.IsNormalTextureConstant}"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="SectionLabel" Text="Emissive"/>
                                                <ComboBox Classes="InspectorCombo"
                                                          ItemsSource="{Binding Material.TextureSlotOptions}"
                                                          SelectedItem="{Binding Material.EmissiveTextureSlot, Mode=TwoWay}"
                                                          IsEnabled="{Binding Material.IsEmissiveTextureConstant}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:TextureSlotOption}">
                                                            <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <ComboBox Classes="InspectorCombo"
                                                          ItemsSource="{Binding Material.TextureSources}"
                                                          SelectedIndex="{Binding Material.EmissiveTextureSourceIndex, Mode=TwoWay}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:ShaderSourceOption}">
                                                            <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBlock Text="{Binding Material.EmissiveStrengthLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Material.EmissiveStrength, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        IsEnabled="{Binding Material.IsEmissiveTextureConstant}"/>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="SectionLabel" Text="Occlusion"/>
                                                <ComboBox Classes="InspectorCombo"
                                                          ItemsSource="{Binding Material.TextureSlotOptions}"
                                                          SelectedItem="{Binding Material.OcclusionTextureSlot, Mode=TwoWay}"
                                                          IsEnabled="{Binding Material.IsOcclusionTextureConstant}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:TextureSlotOption}">
                                                            <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <ComboBox Classes="InspectorCombo"
                                                          ItemsSource="{Binding Material.TextureSources}"
                                                          SelectedIndex="{Binding Material.OcclusionTextureSourceIndex, Mode=TwoWay}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:ShaderSourceOption}">
                                                            <TextBlock Text="{Binding Label}" Foreground="#E8EEF5"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBlock Text="{Binding Material.OcclusionStrengthLabel}" Foreground="#A3AFBD"/>
                                                <Slider Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Material.OcclusionStrength, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        IsEnabled="{Binding Material.IsOcclusionTextureConstant}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander>
                                    <Expander Classes="InspectorRollout" Header="UV" IsExpanded="False">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding Material.UvScaleLabel}" Foreground="#A3AFBD"/>
                                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="6" RowSpacing="4">
                                                <TextBlock Text="Scale X" Foreground="#E8EEF5"/>
                                                <Slider Grid.Column="1"
                                                        Minimum="0.1"
                                                        Maximum="10"
                                                        Value="{Binding Material.UvScaleX, Mode=TwoWay}"
                                                        TickFrequency="0.1"
                                                        SmallChange="0.1"
                                                        LargeChange="0.5"/>
                                                <TextBlock Grid.Row="1" Text="Scale Y" Foreground="#E8EEF5"/>
                                                <Slider Grid.Row="1" Grid.Column="1"
                                                        Minimum="0.1"
                                                        Maximum="10"
                                                        Value="{Binding Material.UvScaleY, Mode=TwoWay}"
                                                        TickFrequency="0.1"
                                                        SmallChange="0.1"
                                                        LargeChange="0.5"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Material.UvOffsetLabel}" Foreground="#A3AFBD"/>
                                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="6" RowSpacing="4">
                                                <TextBlock Text="Offset X" Foreground="#E8EEF5"/>
                                                <Slider Grid.Column="1"
                                                        Minimum="-2"
                                                        Maximum="2"
                                                        Value="{Binding Material.UvOffsetX, Mode=TwoWay}"
                                                        TickFrequency="0.1"
                                                        SmallChange="0.1"
                                                        LargeChange="0.5"/>
                                                <TextBlock Grid.Row="1" Text="Offset Y" Foreground="#E8EEF5"/>
                                                <Slider Grid.Row="1" Grid.Column="1"
                                                        Minimum="-2"
                                                        Maximum="2"
                                                        Value="{Binding Material.UvOffsetY, Mode=TwoWay}"
                                                        TickFrequency="0.1"
                                                        SmallChange="0.1"
                                                        LargeChange="0.5"/>
                                            </Grid>
                                        </StackPanel>
                                    </Expander>
                                    <Expander Classes="InspectorRollout" Header="Phong" IsExpanded="False"
                                              IsEnabled="{Binding Material.IsPhongModel}">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding Material.AmbientLabel}" Foreground="#A3AFBD"/>
                                            <Slider Minimum="0"
                                                    Maximum="1"
                                                    Value="{Binding Material.Ambient, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.1"/>
                                            <TextBlock Text="{Binding Material.DiffuseLabel}" Foreground="#A3AFBD"/>
                                            <Slider Minimum="0"
                                                    Maximum="1"
                                                    Value="{Binding Material.Diffuse, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.1"/>
                                            <TextBlock Text="{Binding Material.SpecularLabel}" Foreground="#A3AFBD"/>
                                            <Slider Minimum="0"
                                                    Maximum="1"
                                                    Value="{Binding Material.Specular, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.1"/>
                                            <TextBlock Text="{Binding Material.ShininessLabel}" Foreground="#A3AFBD"/>
                                            <Slider Minimum="1"
                                                    Maximum="128"
                                                    Value="{Binding Material.Shininess, Mode=TwoWay}"
                                                    TickFrequency="1"
                                                    SmallChange="1"
                                                    LargeChange="8"/>
                                        </StackPanel>
                                    </Expander>
                                    <TextBlock Classes="SectionTitle" Text="Shader Graph"/>
                                    <TextBlock Classes="SectionLabel" Text="Click output then input to connect. Click input to clear."/>
                                    <controls:MaterialGraphCanvasControl DataContext="{Binding Material.Canvas}" Height="320"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Add Color"
                                                Classes="InspectorButton"
                                                Command="{Binding Material.AddColorNodeCommand}"/>
                                        <Button Content="Add Float"
                                                Classes="InspectorButton"
                                                Command="{Binding Material.AddFloatNodeCommand}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Add Add"
                                                Classes="InspectorButton"
                                                Command="{Binding Material.AddAddNodeCommand}"/>
                                        <Button Content="Add Multiply"
                                                Classes="InspectorButton"
                                                Command="{Binding Material.AddMultiplyNodeCommand}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Add Texture"
                                                Classes="InspectorButton"
                                                Command="{Binding Material.AddTextureNodeCommand}"/>
                                        <Button Content="Add Sample"
                                                Classes="InspectorButton"
                                                Command="{Binding Material.AddTextureSampleNodeCommand}"/>
                                    </Grid>
                                    <Button Content="Add Normal Map"
                                            Classes="InspectorButton"
                                            Command="{Binding Material.AddNormalMapNodeCommand}"/>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="VFX (Particles)" IsExpanded="False">
                                <StackPanel Spacing="8" IsEnabled="{Binding Vfx.HasSelection}">
                                    <TextBlock Text="{Binding Vfx.SelectionLabel}" Foreground="#A3AFBD"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Add Emitter"
                                                Classes="InspectorButton"
                                                Command="{Binding Vfx.AddEmitterCommand}"/>
                                        <Button Content="Remove"
                                                Classes="InspectorButton"
                                                Command="{Binding Vfx.RemoveEmitterCommand}"
                                                IsEnabled="{Binding Vfx.HasEmitter}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <CheckBox Content="Enabled"
                                                  Foreground="#E8EEF5"
                                                  IsChecked="{Binding Vfx.EmitterEnabled, Mode=TwoWay}"
                                                  IsEnabled="{Binding Vfx.HasEmitter}"/>
                                        <CheckBox Content="Emitting"
                                                  Foreground="#E8EEF5"
                                                  IsChecked="{Binding Vfx.IsEmitting, Mode=TwoWay}"
                                                  IsEnabled="{Binding Vfx.HasEmitter}"/>
                                    </Grid>
                                    <CheckBox Content="World space"
                                              Foreground="#E8EEF5"
                                              IsChecked="{Binding Vfx.WorldSpace, Mode=TwoWay}"
                                              IsEnabled="{Binding Vfx.HasEmitter}"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Max particles" Foreground="#A3AFBD"/>
                                        <Slider Minimum="10"
                                                Maximum="2000"
                                                Value="{Binding Vfx.MaxParticles, Mode=TwoWay}"
                                                TickFrequency="10"
                                                SmallChange="10"
                                                LargeChange="50"
                                                IsEnabled="{Binding Vfx.HasEmitter}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Emission rate" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0"
                                                Maximum="200"
                                                Value="{Binding Vfx.EmissionRate, Mode=TwoWay}"
                                                TickFrequency="5"
                                                SmallChange="1"
                                                LargeChange="10"
                                                IsEnabled="{Binding Vfx.HasEmitter}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Lifetime" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0.1"
                                                Maximum="10"
                                                Value="{Binding Vfx.Lifetime, Mode=TwoWay}"
                                                TickFrequency="0.1"
                                                SmallChange="0.1"
                                                LargeChange="0.5"
                                                IsEnabled="{Binding Vfx.HasEmitter}"/>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="SectionLabel" Text="Start size" Foreground="#A3AFBD"/>
                                            <Slider Minimum="0.01"
                                                    Maximum="2"
                                                    Value="{Binding Vfx.StartSize, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.2"
                                                    IsEnabled="{Binding Vfx.HasEmitter}"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="SectionLabel" Text="End size" Foreground="#A3AFBD"/>
                                            <Slider Minimum="0"
                                                    Maximum="2"
                                                    Value="{Binding Vfx.EndSize, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.2"
                                                    IsEnabled="{Binding Vfx.HasEmitter}"/>
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Base velocity" Foreground="#A3AFBD"/>
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="4">
                                            <TextBlock Text="X" Foreground="#E8EEF5"/>
                                            <Slider Grid.Column="1"
                                                    Minimum="-5"
                                                    Maximum="5"
                                                    Value="{Binding Vfx.BaseVelX, Mode=TwoWay}"
                                                    TickFrequency="0.5"
                                                    SmallChange="0.1"
                                                    LargeChange="1"
                                                    IsEnabled="{Binding Vfx.HasEmitter}"/>
                                            <TextBlock Grid.Row="1" Text="Y" Foreground="#E8EEF5"/>
                                            <Slider Grid.Row="1" Grid.Column="1"
                                                    Minimum="-5"
                                                    Maximum="5"
                                                    Value="{Binding Vfx.BaseVelY, Mode=TwoWay}"
                                                    TickFrequency="0.5"
                                                    SmallChange="0.1"
                                                    LargeChange="1"
                                                    IsEnabled="{Binding Vfx.HasEmitter}"/>
                                            <TextBlock Grid.Row="2" Text="Z" Foreground="#E8EEF5"/>
                                            <Slider Grid.Row="2" Grid.Column="1"
                                                    Minimum="-5"
                                                    Maximum="5"
                                                    Value="{Binding Vfx.BaseVelZ, Mode=TwoWay}"
                                                    TickFrequency="0.5"
                                                    SmallChange="0.1"
                                                    LargeChange="1"
                                                    IsEnabled="{Binding Vfx.HasEmitter}"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Velocity randomness" Foreground="#A3AFBD"/>
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="4">
                                            <TextBlock Text="X" Foreground="#E8EEF5"/>
                                            <Slider Grid.Column="1"
                                                    Minimum="0"
                                                    Maximum="5"
                                                    Value="{Binding Vfx.VelRandX, Mode=TwoWay}"
                                                    TickFrequency="0.1"
                                                    SmallChange="0.1"
                                                    LargeChange="0.5"
                                                    IsEnabled="{Binding Vfx.HasEmitter}"/>
                                            <TextBlock Grid.Row="1" Text="Y" Foreground="#E8EEF5"/>
                                            <Slider Grid.Row="1" Grid.Column="1"
                                                    Minimum="0"
                                                    Maximum="5"
                                                    Value="{Binding Vfx.VelRandY, Mode=TwoWay}"
                                                    TickFrequency="0.1"
                                                    SmallChange="0.1"
                                                    LargeChange="0.5"
                                                    IsEnabled="{Binding Vfx.HasEmitter}"/>
                                            <TextBlock Grid.Row="2" Text="Z" Foreground="#E8EEF5"/>
                                            <Slider Grid.Row="2" Grid.Column="1"
                                                    Minimum="0"
                                                    Maximum="5"
                                                    Value="{Binding Vfx.VelRandZ, Mode=TwoWay}"
                                                    TickFrequency="0.1"
                                                    SmallChange="0.1"
                                                    LargeChange="0.5"
                                                    IsEnabled="{Binding Vfx.HasEmitter}"/>
                                        </Grid>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="SectionLabel" Text="Start color" Foreground="#A3AFBD"/>
                                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="4">
                                                <TextBlock Text="R" Foreground="#E8EEF5"/>
                                                <Slider Grid.Column="1"
                                                        Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Vfx.StartColorR, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        IsEnabled="{Binding Vfx.HasEmitter}"/>
                                                <TextBlock Grid.Row="1" Text="G" Foreground="#E8EEF5"/>
                                                <Slider Grid.Row="1" Grid.Column="1"
                                                        Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Vfx.StartColorG, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        IsEnabled="{Binding Vfx.HasEmitter}"/>
                                                <TextBlock Grid.Row="2" Text="B" Foreground="#E8EEF5"/>
                                                <Slider Grid.Row="2" Grid.Column="1"
                                                        Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Vfx.StartColorB, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        IsEnabled="{Binding Vfx.HasEmitter}"/>
                                                <TextBlock Grid.Row="3" Text="A" Foreground="#E8EEF5"/>
                                                <Slider Grid.Row="3" Grid.Column="1"
                                                        Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Vfx.StartColorA, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        IsEnabled="{Binding Vfx.HasEmitter}"/>
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="SectionLabel" Text="End color" Foreground="#A3AFBD"/>
                                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="4">
                                                <TextBlock Text="R" Foreground="#E8EEF5"/>
                                                <Slider Grid.Column="1"
                                                        Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Vfx.EndColorR, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        IsEnabled="{Binding Vfx.HasEmitter}"/>
                                                <TextBlock Grid.Row="1" Text="G" Foreground="#E8EEF5"/>
                                                <Slider Grid.Row="1" Grid.Column="1"
                                                        Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Vfx.EndColorG, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        IsEnabled="{Binding Vfx.HasEmitter}"/>
                                                <TextBlock Grid.Row="2" Text="B" Foreground="#E8EEF5"/>
                                                <Slider Grid.Row="2" Grid.Column="1"
                                                        Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Vfx.EndColorB, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        IsEnabled="{Binding Vfx.HasEmitter}"/>
                                                <TextBlock Grid.Row="3" Text="A" Foreground="#E8EEF5"/>
                                                <Slider Grid.Row="3" Grid.Column="1"
                                                        Minimum="0"
                                                        Maximum="1"
                                                        Value="{Binding Vfx.EndColorA, Mode=TwoWay}"
                                                        TickFrequency="0.05"
                                                        SmallChange="0.05"
                                                        LargeChange="0.1"
                                                        IsEnabled="{Binding Vfx.HasEmitter}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Physics" IsExpanded="False">
                                <StackPanel Spacing="8" IsEnabled="{Binding Physics.HasSelection}">
                                    <TextBlock Text="{Binding Physics.SelectionLabel}" Foreground="#A3AFBD"/>
                                    <TextBlock Classes="SectionTitle" Text="Rigid Body"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Add"
                                                Classes="InspectorButton"
                                                Command="{Binding Physics.AddRigidBodyCommand}"/>
                                        <Button Content="Remove"
                                                Classes="InspectorButton"
                                                Command="{Binding Physics.RemoveRigidBodyCommand}"
                                                IsEnabled="{Binding Physics.HasRigidBody}"/>
                                    </Grid>
                                    <CheckBox Content="Enabled"
                                              Foreground="#E8EEF5"
                                              IsChecked="{Binding Physics.BodyEnabled, Mode=TwoWay}"
                                              IsEnabled="{Binding Physics.HasRigidBody}"/>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <TextBlock Classes="SectionLabel" Text="Body type" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1"
                                                  Classes="InspectorCombo"
                                                  SelectedIndex="{Binding Physics.BodyTypeIndex, Mode=TwoWay}"
                                                  IsEnabled="{Binding Physics.HasRigidBody}">
                                            <ComboBoxItem Content="Static"/>
                                            <ComboBoxItem Content="Dynamic"/>
                                            <ComboBoxItem Content="Kinematic"/>
                                        </ComboBox>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Mass" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0.01"
                                                Maximum="50"
                                                Value="{Binding Physics.Mass, Mode=TwoWay}"
                                                TickFrequency="0.1"
                                                SmallChange="0.1"
                                                LargeChange="1"
                                                IsEnabled="{Binding Physics.HasRigidBody}"/>
                                    </StackPanel>
                                    <CheckBox Content="Use gravity"
                                              Foreground="#E8EEF5"
                                              IsChecked="{Binding Physics.UseGravity, Mode=TwoWay}"
                                              IsEnabled="{Binding Physics.HasRigidBody}"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Restitution" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0"
                                                Maximum="1"
                                                Value="{Binding Physics.Restitution, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"
                                                IsEnabled="{Binding Physics.HasRigidBody}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Friction" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0"
                                                Maximum="1"
                                                Value="{Binding Physics.Friction, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"
                                                IsEnabled="{Binding Physics.HasRigidBody}"/>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="SectionLabel" Text="Linear damping" Foreground="#A3AFBD"/>
                                            <Slider Minimum="0"
                                                    Maximum="1"
                                                    Value="{Binding Physics.LinearDamping, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.1"
                                                    IsEnabled="{Binding Physics.HasRigidBody}"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="SectionLabel" Text="Angular damping" Foreground="#A3AFBD"/>
                                            <Slider Minimum="0"
                                                    Maximum="1"
                                                    Value="{Binding Physics.AngularDamping, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.1"
                                                    IsEnabled="{Binding Physics.HasRigidBody}"/>
                                        </StackPanel>
                                    </Grid>
                                    <CheckBox Content="Awake"
                                              Foreground="#E8EEF5"
                                              IsChecked="{Binding Physics.IsAwake, Mode=TwoWay}"
                                              IsEnabled="{Binding Physics.HasRigidBody}"/>
                                    <TextBlock Classes="SectionTitle" Text="Collider"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Add"
                                                Classes="InspectorButton"
                                                Command="{Binding Physics.AddColliderCommand}"/>
                                        <Button Content="Remove"
                                                Classes="InspectorButton"
                                                Command="{Binding Physics.RemoveColliderCommand}"
                                                IsEnabled="{Binding Physics.HasCollider}"/>
                                    </Grid>
                                    <CheckBox Content="Enabled"
                                              Foreground="#E8EEF5"
                                              IsChecked="{Binding Physics.ColliderEnabled, Mode=TwoWay}"
                                              IsEnabled="{Binding Physics.HasCollider}"/>
                                    <CheckBox Content="Trigger"
                                              Foreground="#E8EEF5"
                                              IsChecked="{Binding Physics.IsTrigger, Mode=TwoWay}"
                                              IsEnabled="{Binding Physics.HasCollider}"/>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <TextBlock Classes="SectionLabel" Text="Shape" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1"
                                                  Classes="InspectorCombo"
                                                  SelectedIndex="{Binding Physics.ColliderShapeIndex, Mode=TwoWay}"
                                                  IsEnabled="{Binding Physics.HasCollider}">
                                            <ComboBoxItem Content="Sphere"/>
                                            <ComboBoxItem Content="Box"/>
                                        </ComboBox>
                                    </Grid>
                                    <StackPanel Spacing="4" IsVisible="{Binding Physics.IsSphereCollider}">
                                        <TextBlock Classes="SectionLabel" Text="Radius" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0.01"
                                                Maximum="10"
                                                Value="{Binding Physics.ColliderRadius, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.5"
                                                IsEnabled="{Binding Physics.HasCollider}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4" IsVisible="{Binding Physics.IsBoxCollider}">
                                        <TextBlock Classes="SectionLabel" Text="Size" Foreground="#A3AFBD"/>
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="4">
                                            <TextBlock Text="X" Foreground="#E8EEF5"/>
                                            <Slider Grid.Column="1"
                                                    Minimum="0.01"
                                                    Maximum="10"
                                                    Value="{Binding Physics.ColliderSizeX, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.5"
                                                    IsEnabled="{Binding Physics.HasCollider}"/>
                                            <TextBlock Grid.Row="1" Text="Y" Foreground="#E8EEF5"/>
                                            <Slider Grid.Row="1" Grid.Column="1"
                                                    Minimum="0.01"
                                                    Maximum="10"
                                                    Value="{Binding Physics.ColliderSizeY, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.5"
                                                    IsEnabled="{Binding Physics.HasCollider}"/>
                                            <TextBlock Grid.Row="2" Text="Z" Foreground="#E8EEF5"/>
                                            <Slider Grid.Row="2" Grid.Column="1"
                                                    Minimum="0.01"
                                                    Maximum="10"
                                                    Value="{Binding Physics.ColliderSizeZ, Mode=TwoWay}"
                                                    TickFrequency="0.05"
                                                    SmallChange="0.05"
                                                    LargeChange="0.5"
                                                    IsEnabled="{Binding Physics.HasCollider}"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Offset" Foreground="#A3AFBD"/>
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="4">
                                            <TextBlock Text="X" Foreground="#E8EEF5"/>
                                            <Slider Grid.Column="1"
                                                    Minimum="-5"
                                                    Maximum="5"
                                                    Value="{Binding Physics.ColliderOffsetX, Mode=TwoWay}"
                                                    TickFrequency="0.1"
                                                    SmallChange="0.1"
                                                    LargeChange="0.5"
                                                    IsEnabled="{Binding Physics.HasCollider}"/>
                                            <TextBlock Grid.Row="1" Text="Y" Foreground="#E8EEF5"/>
                                            <Slider Grid.Row="1" Grid.Column="1"
                                                    Minimum="-5"
                                                    Maximum="5"
                                                    Value="{Binding Physics.ColliderOffsetY, Mode=TwoWay}"
                                                    TickFrequency="0.1"
                                                    SmallChange="0.1"
                                                    LargeChange="0.5"
                                                    IsEnabled="{Binding Physics.HasCollider}"/>
                                            <TextBlock Grid.Row="2" Text="Z" Foreground="#E8EEF5"/>
                                            <Slider Grid.Row="2" Grid.Column="1"
                                                    Minimum="-5"
                                                    Maximum="5"
                                                    Value="{Binding Physics.ColliderOffsetZ, Mode=TwoWay}"
                                                    TickFrequency="0.1"
                                                    SmallChange="0.1"
                                                    LargeChange="0.5"
                                                    IsEnabled="{Binding Physics.HasCollider}"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Navigation" IsExpanded="False">
                                <StackPanel Spacing="8" IsEnabled="{Binding Navigation.HasSelection}">
                                    <TextBlock Text="{Binding Navigation.SelectionLabel}" Foreground="#A3AFBD"/>
                                    <TextBlock Classes="SectionTitle" Text="Nav Grid"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Add"
                                                Classes="InspectorButton"
                                                Command="{Binding Navigation.AddGridCommand}"/>
                                        <Button Content="Remove"
                                                Classes="InspectorButton"
                                                Command="{Binding Navigation.RemoveGridCommand}"
                                                IsEnabled="{Binding Navigation.HasNavGrid}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="SectionLabel" Text="Width" Foreground="#A3AFBD"/>
                                            <Slider Minimum="2"
                                                    Maximum="128"
                                                    TickFrequency="1"
                                                    IsSnapToTickEnabled="True"
                                                    Value="{Binding Navigation.GridWidth, Mode=TwoWay}"
                                                    IsEnabled="{Binding Navigation.HasNavGrid}"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="SectionLabel" Text="Height" Foreground="#A3AFBD"/>
                                            <Slider Minimum="2"
                                                    Maximum="128"
                                                    TickFrequency="1"
                                                    IsSnapToTickEnabled="True"
                                                    Value="{Binding Navigation.GridHeight, Mode=TwoWay}"
                                                    IsEnabled="{Binding Navigation.HasNavGrid}"/>
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Cell size" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0.2"
                                                Maximum="5"
                                                Value="{Binding Navigation.CellSize, Mode=TwoWay}"
                                                TickFrequency="0.1"
                                                SmallChange="0.1"
                                                LargeChange="0.5"
                                                IsEnabled="{Binding Navigation.HasNavGrid}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Origin" Foreground="#A3AFBD"/>
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="4">
                                            <TextBlock Text="X" Foreground="#E8EEF5"/>
                                            <Slider Grid.Column="1"
                                                    Minimum="-20"
                                                    Maximum="20"
                                                    Value="{Binding Navigation.OriginX, Mode=TwoWay}"
                                                    TickFrequency="0.5"
                                                    SmallChange="0.5"
                                                    LargeChange="2"
                                                    IsEnabled="{Binding Navigation.HasNavGrid}"/>
                                            <TextBlock Grid.Row="1" Text="Y" Foreground="#E8EEF5"/>
                                            <Slider Grid.Row="1" Grid.Column="1"
                                                    Minimum="-10"
                                                    Maximum="10"
                                                    Value="{Binding Navigation.OriginY, Mode=TwoWay}"
                                                    TickFrequency="0.5"
                                                    SmallChange="0.5"
                                                    LargeChange="2"
                                                    IsEnabled="{Binding Navigation.HasNavGrid}"/>
                                            <TextBlock Grid.Row="2" Text="Z" Foreground="#E8EEF5"/>
                                            <Slider Grid.Row="2" Grid.Column="1"
                                                    Minimum="-20"
                                                    Maximum="20"
                                                    Value="{Binding Navigation.OriginZ, Mode=TwoWay}"
                                                    TickFrequency="0.5"
                                                    SmallChange="0.5"
                                                    LargeChange="2"
                                                    IsEnabled="{Binding Navigation.HasNavGrid}"/>
                                        </Grid>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Apply Grid"
                                                Classes="InspectorButton"
                                                Command="{Binding Navigation.ApplyGridCommand}"
                                                IsEnabled="{Binding Navigation.HasNavGrid}"/>
                                        <Button Content="Bake From Bounds"
                                                Classes="InspectorButton"
                                                Command="{Binding Navigation.BakeGridCommand}"/>
                                    </Grid>
                                    <TextBlock Classes="SectionTitle" Text="Agent"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Add"
                                                Classes="InspectorButton"
                                                Command="{Binding Navigation.AddAgentCommand}"/>
                                        <Button Content="Remove"
                                                Classes="InspectorButton"
                                                Command="{Binding Navigation.RemoveAgentCommand}"
                                                IsEnabled="{Binding Navigation.HasNavAgent}"/>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Speed" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0.1"
                                                Maximum="10"
                                                Value="{Binding Navigation.AgentSpeed, Mode=TwoWay}"
                                                TickFrequency="0.1"
                                                SmallChange="0.1"
                                                LargeChange="0.5"
                                                IsEnabled="{Binding Navigation.HasNavAgent}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Stopping distance" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0.01"
                                                Maximum="2"
                                                Value="{Binding Navigation.AgentStoppingDistance, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.2"
                                                IsEnabled="{Binding Navigation.HasNavAgent}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Destination" Foreground="#A3AFBD"/>
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="4">
                                            <TextBlock Text="X" Foreground="#E8EEF5"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Navigation.DestinationX, Mode=TwoWay}"
                                                     IsEnabled="{Binding Navigation.HasNavAgent}"/>
                                            <TextBlock Grid.Row="1" Text="Y" Foreground="#E8EEF5"/>
                                            <TextBox Grid.Row="1" Grid.Column="1"
                                                     Text="{Binding Navigation.DestinationY, Mode=TwoWay}"
                                                     IsEnabled="{Binding Navigation.HasNavAgent}"/>
                                            <TextBlock Grid.Row="2" Text="Z" Foreground="#E8EEF5"/>
                                            <TextBox Grid.Row="2" Grid.Column="1"
                                                     Text="{Binding Navigation.DestinationZ, Mode=TwoWay}"
                                                     IsEnabled="{Binding Navigation.HasNavAgent}"/>
                                        </Grid>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Set Destination"
                                                Classes="InspectorButton"
                                                Command="{Binding Navigation.ApplyDestinationCommand}"
                                                IsEnabled="{Binding Navigation.HasNavAgent}"/>
                                        <Button Content="Clear"
                                                Classes="InspectorButton"
                                                Command="{Binding Navigation.ClearDestinationCommand}"
                                                IsEnabled="{Binding Navigation.HasNavAgent}"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Navigation.PathLabel}" Foreground="#A3AFBD"/>
                                </StackPanel>
                            </Expander>
                            <Expander Classes="InspectorRollout" Header="Audio" IsExpanded="False">
                                <StackPanel Spacing="8" IsEnabled="{Binding Audio.HasSelection}">
                                    <TextBlock Text="{Binding Audio.SelectionLabel}" Foreground="#A3AFBD"/>
                                    <TextBlock Classes="SectionTitle" Text="Listener"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Add"
                                                Classes="InspectorButton"
                                                Command="{Binding Audio.AddListenerCommand}"/>
                                        <Button Content="Remove"
                                                Classes="InspectorButton"
                                                Command="{Binding Audio.RemoveListenerCommand}"
                                                IsEnabled="{Binding Audio.HasListener}"/>
                                    </Grid>
                                    <CheckBox Content="Enabled"
                                              Foreground="#E8EEF5"
                                              IsChecked="{Binding Audio.ListenerEnabled, Mode=TwoWay}"
                                              IsEnabled="{Binding Audio.HasListener}"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Volume" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0"
                                                Maximum="2"
                                                Value="{Binding Audio.ListenerVolume, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"
                                                IsEnabled="{Binding Audio.HasListener}"/>
                                    </StackPanel>
                                    <TextBlock Classes="SectionTitle" Text="Source"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Add"
                                                Classes="InspectorButton"
                                                Command="{Binding Audio.AddSourceCommand}"/>
                                        <Button Content="Remove"
                                                Classes="InspectorButton"
                                                Command="{Binding Audio.RemoveSourceCommand}"
                                                IsEnabled="{Binding Audio.HasSource}"/>
                                    </Grid>
                                    <CheckBox Content="Enabled"
                                              Foreground="#E8EEF5"
                                              IsChecked="{Binding Audio.SourceEnabled, Mode=TwoWay}"
                                              IsEnabled="{Binding Audio.HasSource}"/>
                                    <CheckBox Content="Loop"
                                              Foreground="#E8EEF5"
                                              IsChecked="{Binding Audio.SourceLoop, Mode=TwoWay}"
                                              IsEnabled="{Binding Audio.HasSource}"/>
                                    <TextBlock Text="{Binding Audio.ClipLabel}" Foreground="#A3AFBD"/>
                                    <TextBlock Text="{Binding Audio.PlaybackLabel}" Foreground="#A3AFBD"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Play"
                                                Classes="InspectorButton"
                                                Command="{Binding Audio.PlayCommand}"
                                                IsEnabled="{Binding Audio.HasSource}"/>
                                        <Button Content="Stop"
                                                Classes="InspectorButton"
                                                Command="{Binding Audio.StopCommand}"
                                                IsEnabled="{Binding Audio.HasSource}"/>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Clip duration" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0.1"
                                                Maximum="5"
                                                Value="{Binding Audio.ClipDuration, Mode=TwoWay}"
                                                TickFrequency="0.1"
                                                SmallChange="0.1"
                                                LargeChange="0.5"
                                                IsEnabled="{Binding Audio.HasSource}"/>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Content="Create Clip"
                                                Classes="InspectorButton"
                                                Command="{Binding Audio.CreateClipCommand}"
                                                IsEnabled="{Binding Audio.HasSource}"/>
                                        <Button Content="Clear Clip"
                                                Classes="InspectorButton"
                                                Command="{Binding Audio.ClearClipCommand}"
                                                IsEnabled="{Binding Audio.HasSource}"/>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Volume" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0"
                                                Maximum="2"
                                                Value="{Binding Audio.SourceVolume, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"
                                                IsEnabled="{Binding Audio.HasSource}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Pitch" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0.5"
                                                Maximum="2"
                                                Value="{Binding Audio.SourcePitch, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"
                                                IsEnabled="{Binding Audio.HasSource}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="SectionLabel" Text="Spatial blend" Foreground="#A3AFBD"/>
                                        <Slider Minimum="0"
                                                Maximum="1"
                                                Value="{Binding Audio.SourceSpatialBlend, Mode=TwoWay}"
                                                TickFrequency="0.05"
                                                SmallChange="0.05"
                                                LargeChange="0.1"
                                                IsEnabled="{Binding Audio.HasSource}"/>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="SectionLabel" Text="Min distance" Foreground="#A3AFBD"/>
                                            <Slider Minimum="0.1"
                                                    Maximum="50"
                                                    Value="{Binding Audio.SourceMinDistance, Mode=TwoWay}"
                                                    TickFrequency="0.5"
                                                    SmallChange="0.5"
                                                    LargeChange="2"
                                                    IsEnabled="{Binding Audio.HasSource}"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="SectionLabel" Text="Max distance" Foreground="#A3AFBD"/>
                                            <Slider Minimum="1"
                                                    Maximum="100"
                                                    Value="{Binding Audio.SourceMaxDistance, Mode=TwoWay}"
                                                    TickFrequency="1"
                                                    SmallChange="1"
                                                    LargeChange="5"
                                                    IsEnabled="{Binding Audio.HasSource}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Skia3D.Sample.ViewModels"
             mc:Ignorable="d"
             x:Class="Skia3D.Sample.Controls.StatusBarControl"
             x:DataType="vm:MainWindowViewModel">
    <Border Background="#2A2F35"
            BorderBrush="#1F2328"
            BorderThickness="0,1,0,0"
            Padding="10,4">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
              ColumnSpacing="16"
              VerticalAlignment="Center">
            <TextBlock Text="{Binding StatusBar.HelpText}"
                       Foreground="#9AA4AF"
                       FontSize="11"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"/>
            <Grid Grid.Column="1"
                  ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="10"
                  VerticalAlignment="Center"
                  IsVisible="{Binding Workspace.ShowTimeline}">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <ToggleButton Classes="MaxStatusButton"
                                  Content="{Binding CommandPanel.Motion.PlayLabel}"
                                  IsChecked="{Binding CommandPanel.Motion.IsPlaying}"
                                  IsEnabled="{Binding CommandPanel.Motion.CanPlay}"
                                  ToolTip.Tip="Play/Pause"/>
                    <ToggleButton Classes="MaxStatusButton"
                                  Content="Loop"
                                  IsChecked="{Binding CommandPanel.Motion.Loop}"
                                  IsEnabled="{Binding CommandPanel.Motion.CanLoop}"
                                  ToolTip.Tip="Loop"/>
                    <Button Classes="MaxStatusButton"
                            Content="Reset"
                            Command="{Binding Actions.AnimationResetCommand}"
                            IsEnabled="{Binding CommandPanel.Motion.CanReset}"
                            ToolTip.Tip="Reset"/>
                </StackPanel>
                <Slider Grid.Column="1"
                        Classes="MaxStatusSlider"
                        Minimum="0"
                        Maximum="{Binding CommandPanel.Motion.TimeMax}"
                        Value="{Binding CommandPanel.Motion.Time}"
                        IsEnabled="{Binding CommandPanel.Motion.CanScrub}"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding CommandPanel.Motion.TimeLabel}"
                           Classes="MaxStatusTime"
                           VerticalAlignment="Center"/>
            </Grid>
            <TextBlock Grid.Column="2"
                       Text="{Binding StatusBar.SelectionText}"
                       Foreground="#A8B0BA"
                       FontSize="11"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="3"
                       Text="{Binding StatusBar.FpsText}"
                       Foreground="#E4E8EE"
                       FontSize="11"
                       TextWrapping="NoWrap"
                       Margin="0"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="4"
                       Text="{Binding StatusBar.RenderText}"
                       Foreground="#A8B0BA"
                       FontSize="11"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>

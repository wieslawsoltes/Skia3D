        </Style>
        <Style Selector="ToggleButton.MaxPanelTab:checked">
            <Setter Property="Background" Value="#363C43"/>
            <Setter Property="Foreground" Value="#E4E8EE"/>
        </Style>
        <Style Selector="RadioButton.MaxPanelTab">

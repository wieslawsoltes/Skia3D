        </Style>
        <Style Selector="TabItem.InspectorTab">
            <Setter Property="Foreground" Value="#A3AFBD"/>
            <Setter Property="Background" Value="#111820"/>
            <Setter Property="BorderBrush" Value="#2A3644"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="MinWidth" Value="48"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TabItem.InspectorTab:pointerover">
            <Setter Property="Foreground" Value="#E8EEF5"/>
        </Style>
        <Style Selector="TabItem.InspectorTab:selected">
            <Setter Property="Foreground" Value="#E8EEF5"/>

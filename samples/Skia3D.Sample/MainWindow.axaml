            <Setter Property="BorderBrush" Value="#1F2328"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
        <Style Selector="RadioButton.MaxPanelTab:pointerover">
            <Setter Property="Foreground" Value="#E4E8EE"/>
        </Style>
        <Style Selector="RadioButton.MaxPanelTab:checked">
            <Setter Property="Background" Value="#363C43"/>
            <Setter Property="Foreground" Value="#E4E8EE"/>
        </Style>
        <Style Selector="Border.GraphCanvas">
            <Setter Property="Background" Value="#24292F"/>
            <Setter Property="BorderBrush" Value="#1F2328"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
        </Style>
        <Style Selector="Border.GraphNode">
            <Setter Property="Background" Value="#2D3238"/>
            <Setter Property="BorderBrush" Value="#1F2328"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="BoxShadow" Value="0 8 18 0 #55000000"/>
        </Style>
        <Style Selector="Border.GraphNodeHeader">
            <Setter Property="Background" Value="#363C43"/>
            <Setter Property="BorderBrush" Value="#1F2328"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="CornerRadius" Value="2,2,0,0"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style Selector="TextBlock.GraphNodeTitle">
            <Setter Property="Foreground" Value="#E4E8EE"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="Button.GraphPort">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style Selector="Button.GraphPort:pointerover">
            <Setter Property="Background" Value="#3A424B"/>
        </Style>
        <Style Selector="TextBlock.GraphPortLabel">
            <Setter Property="Foreground" Value="#A8B0BA"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
        <Style Selector="TextBlock.GraphNodeDetailLabel">
            <Setter Property="Foreground" Value="#A8B0BA"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
        <Style Selector="TextBlock.GraphNodeDetailKey">
            <Setter Property="Foreground" Value="#C6D0DA"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox.GraphNodeCombo">
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Background" Value="#2F353B"/>
            <Setter Property="BorderBrush" Value="#1F2328"/>
        </Style>
        <Style Selector="TabControl.InspectorTabs">
            <Setter Property="Background" Value="#10161E"/>
        </Style>
        <Style Selector="TabControl.InspectorTabs /template/ TabStrip#PART_TabStrip">
            <Setter Property="Background" Value="#111820"/>
            <Setter Property="BorderBrush" Value="#2A3644"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Width" Value="54"/>
        </Style>
        <Style Selector="TabItem.InspectorTab">
            <Setter Property="Foreground" Value="#A3AFBD"/>
            <Setter Property="Background" Value="#111820"/>
            <Setter Property="BorderBrush" Value="#2A3644"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="MinWidth" Value="48"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="TabItem.InspectorTab:pointerover">
            <Setter Property="Foreground" Value="#E8EEF5"/>
        </Style>
        <Style Selector="TabItem.InspectorTab:selected">
            <Setter Property="Foreground" Value="#E8EEF5"/>
            <Setter Property="Background" Value="#1B2430"/>
        </Style>
        <Style Selector="Path.TabIcon">
            <Setter Property="Stroke" Value="#A3AFBD"/>
            <Setter Property="StrokeThickness" Value="1.6"/>
            <Setter Property="StrokeLineCap" Value="Round"/>
            <Setter Property="StrokeJoin" Value="Round"/>
            <Setter Property="Fill" Value="Transparent"/>
        </Style>
        <Style Selector="Path.TabIconFilled">
            <Setter Property="Fill" Value="#A3AFBD"/>
            <Setter Property="Stroke" Value="#A3AFBD"/>
        </Style>
        <Style Selector="TabItem.InspectorTab:pointerover Path.TabIcon">
            <Setter Property="Stroke" Value="#E8EEF5"/>
        </Style>
        <Style Selector="TabItem.InspectorTab:pointerover Path.TabIconFilled">
            <Setter Property="Fill" Value="#E8EEF5"/>
            <Setter Property="Stroke" Value="#E8EEF5"/>
        </Style>
        <Style Selector="TabItem.InspectorTab:selected Path.TabIcon">
            <Setter Property="Stroke" Value="#E8EEF5"/>
        </Style>
        <Style Selector="TabItem.InspectorTab:selected Path.TabIconFilled">
            <Setter Property="Fill" Value="#E8EEF5"/>
            <Setter Property="Stroke" Value="#E8EEF5"/>
        </Style>
    </Window.Styles>
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
        <Border Grid.Row="0"
                Background="#2C3137"
                BorderBrush="#1F2328"
                BorderThickness="0,0,0,1"
                Padding="6,2">
            <Menu x:Name="MainMenu" Background="Transparent">
                <MenuItem Header="_File">
                    <MenuItem Header="Open Scene..." Command="{Binding Actions.OpenSceneCommand}"/>
                    <MenuItem Header="Save Scene" Command="{Binding Actions.SaveSceneCommand}"/>
                    <MenuItem Header="Save Scene As..." Command="{Binding Actions.SaveSceneAsCommand}"/>
                    <Separator/>
                    <MenuItem Header="Import Mesh..." Command="{Binding Actions.LoadObjCommand}"/>
                    <MenuItem Header="Zoom Extents" Command="{Binding Actions.ZoomExtentsCommand}"/>
                    <MenuItem Header="Clear Scene" Command="{Binding Actions.ClearSceneCommand}"/>
                </MenuItem>
                <MenuItem Header="_Edit">
                    <MenuItem Header="Undo" Command="{Binding Actions.UndoCommand}"/>
                    <MenuItem Header="Redo" Command="{Binding Actions.RedoCommand}"/>
                </MenuItem>
                <MenuItem Header="_Tools" IsEnabled="False"/>
                <MenuItem Header="_Group" IsEnabled="False"/>
                <MenuItem Header="_Views" IsEnabled="False"/>
                <MenuItem Header="_Create" IsEnabled="False"/>
                <MenuItem Header="_Modifiers" IsEnabled="False"/>
                <MenuItem Header="_Animation" IsEnabled="False"/>
                <MenuItem Header="_Graph Editors" IsEnabled="False"/>
                <MenuItem Header="_Rendering" IsEnabled="False"/>
                <MenuItem Header="_Civil View" IsEnabled="False"/>
                <MenuItem Header="_Customize" IsEnabled="False"/>
                <MenuItem Header="_Scripting" IsEnabled="False"/>
                <MenuItem Header="_Content" IsEnabled="False"/>
                <MenuItem Header="_Help">
                    <MenuItem Header="Shortcut Reference"
                              Command="{Binding Actions.ToggleShortcutsCommand}"/>
                    <MenuItem Header="About" IsEnabled="False"/>
                </MenuItem>
            </Menu>
        </Border>
        <primitives:Popup IsOpen="{Binding Actions.IsShortcutsOpen, Mode=TwoWay}"
                          PlacementTarget="{Binding ElementName=MainMenu}"
                          Placement="Bottom"
                          HorizontalOffset="0"
                          VerticalOffset="4"
                          IsLightDismissEnabled="True">
            <Border Classes="MaxPopupPanel"
                    Width="380"
                    x:DataType="vm:MainWindowViewModel">
                <Grid RowDefinitions="Auto,*">
                    <Border Classes="MaxPopupHeader">
                        <DockPanel LastChildFill="True">
                            <TextBlock Text="Shortcut Reference" Classes="MaxPopupTitle" DockPanel.Dock="Left"/>
                            <Button Classes="MaxToolbarIcon"
                                    Command="{Binding Actions.CloseShortcutsCommand}"
                                    DockPanel.Dock="Right"
                                    Width="22"
                                    Height="22">
                                <Viewbox Width="12" Height="12">
                                    <Path Classes="MaxToolbarGlyph" Data="M4,4 L12,12 M12,4 L4,12"/>
                                </Viewbox>
                            </Button>
                        </DockPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="10" Margin="10">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="Navigation"/>
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="4">
                                    <TextBlock Grid.Row="0" Text="MMB" Classes="ShortcutKey"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Pan viewport" Classes="ShortcutDescription"/>
                                    <TextBlock Grid.Row="1" Text="Alt + MMB" Classes="ShortcutKey"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Orbit viewport" Classes="ShortcutDescription"/>
                                    <TextBlock Grid.Row="2" Text="Wheel" Classes="ShortcutKey"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Zoom" Classes="ShortcutDescription"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <DockPanel LastChildFill="True">
                                    <TextBlock Classes="SectionTitle" Text="Selection" DockPanel.Dock="Left"/>
                                    <TextBlock Classes="ShortcutState"
                                               Text="{Binding Toolbar.Options.SelectionToolStatusLabel}"
                                               DockPanel.Dock="Right"/>
                                </DockPanel>
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="4">
                                    <TextBlock Grid.Row="0" Text="Q" Classes="ShortcutKey"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Click select" Classes="ShortcutDescription"/>
                                    <TextBlock Grid.Row="1" Text="B" Classes="ShortcutKey"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Box select" Classes="ShortcutDescription"/>
                                    <TextBlock Grid.Row="2" Text="V" Classes="ShortcutKey"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Paint select" Classes="ShortcutDescription"/>
                                    <TextBlock Grid.Row="3" Text="A" Classes="ShortcutKey"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Lasso select" Classes="ShortcutDescription"/>
                                    <TextBlock Grid.Row="4" Text="X" Classes="ShortcutKey"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="Toggle crossing" Classes="ShortcutDescription"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="Transform"/>
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="4">
                                    <TextBlock Grid.Row="0" Text="W" Classes="ShortcutKey"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Move tool" Classes="ShortcutDescription"/>
                                    <TextBlock Grid.Row="1" Text="E" Classes="ShortcutKey"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Rotate tool" Classes="ShortcutDescription"/>
                                    <TextBlock Grid.Row="2" Text="R" Classes="ShortcutKey"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Scale tool" Classes="ShortcutDescription"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="Display"/>
                                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="4">
                                    <TextBlock Grid.Row="0" Text="G" Classes="ShortcutKey"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Toggle grid" Classes="ShortcutDescription"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Toolbar.Options.GridStateLabel}" Classes="ShortcutState"/>
                                    <TextBlock Grid.Row="1" Text="Z" Classes="ShortcutKey"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Toggle wireframe" Classes="ShortcutDescription"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Toolbar.Options.WireframeStateLabel}" Classes="ShortcutState"/>
                                    <TextBlock Grid.Row="2" Text="S" Classes="ShortcutKey"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Toggle snap" Classes="ShortcutDescription"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding Toolbar.Options.SnapStateLabel}" Classes="ShortcutState"/>
                                    <TextBlock Grid.Row="3" Text="F" Classes="ShortcutKey"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Zoom extents" Classes="ShortcutDescription"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Classes="SectionTitle" Text="General"/>
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="4">
                                    <TextBlock Grid.Row="0" Text="Ctrl + Z" Classes="ShortcutKey"
                                               IsEnabled="{Binding Editor.CanUndo}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Undo" Classes="ShortcutDescription"
                                               IsEnabled="{Binding Editor.CanUndo}"/>
                                    <TextBlock Grid.Row="1" Text="Ctrl + Y" Classes="ShortcutKey"
                                               IsEnabled="{Binding Editor.CanRedo}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Redo" Classes="ShortcutDescription"
                                               IsEnabled="{Binding Editor.CanRedo}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </primitives:Popup>
        <controls:MainToolbarControl Grid.Row="1"
                                     DataContext="{Binding Toolbar}"/>
        <controls:SecondaryToolbarControl Grid.Row="2"
                                          DataContext="{Binding Toolbar}"/>
        <controls:GraphiteRibbonControl Grid.Row="3"
                                         DataContext="{Binding Toolbar}"
                                         IsVisible="{Binding Workspace.ShowRibbon}"/>
        <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto">
            <Grid Grid.Column="0"
                  Margin="8,8,6,8"
                  IsVisible="{Binding Workspace.ShowSceneExplorer}">
                <controls:SceneExplorerControl DataContext="{Binding CommandPanel}"/>
            </Grid>
            <Grid Grid.Column="1" ColumnDefinitions="Auto,*" Margin="0,8,6,8">
                <controls:ViewportToolbarControl Grid.Column="0"
                                                 DataContext="{Binding Toolbar}"
                                                 IsVisible="{Binding Workspace.ShowViewportToolbar}"/>
                <Border Grid.Column="1"
                        Background="#1E2227"
                        BorderBrush="#1F2328"
                        BorderThickness="1"
                        CornerRadius="2"
                        ClipToBounds="True">
                    <Grid Background="#1F2328"
                          RowDefinitions="*,*"
                          ColumnDefinitions="*,*"
                          RowSpacing="1"
                          ColumnSpacing="1">
                        <Border Grid.Row="0" Grid.Column="0" Background="#1E2227">
                            <Grid>
                                <controls:EditorViewportControl x:Name="ViewportTop"/>
                                <Border Classes="MaxViewportLabel"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="6">
                                    <TextBlock Text="Top" Classes="MaxViewportLabelText"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" Background="#1E2227">
                            <Grid>
                                <controls:EditorViewportControl x:Name="ViewportFront"/>
                                <Border Classes="MaxViewportLabel"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="6">
                                    <TextBlock Text="Front" Classes="MaxViewportLabelText"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0" Background="#1E2227">
                            <Grid>
                                <controls:EditorViewportControl x:Name="ViewportLeft"/>
                                <Border Classes="MaxViewportLabel"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="6">
                                    <TextBlock Text="Left" Classes="MaxViewportLabelText"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Background="#1E2227">
                            <Grid>
                                <controls:EditorViewportControl x:Name="ViewportPerspective"/>
                                <Grid>
                                    <Border Classes="MaxViewportLabel"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Margin="6">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ComboBox Classes="MaxViewportCombo"
                                                      SelectedIndex="{Binding Toolbar.Options.ViewportViewIndex, Mode=TwoWay}">
                                                <ComboBoxItem Classes="MaxViewportComboItem" Content="Perspective"/>
                                                <ComboBoxItem Classes="MaxViewportComboItem" Content="Top"/>
                                                <ComboBoxItem Classes="MaxViewportComboItem" Content="Front"/>
                                                <ComboBoxItem Classes="MaxViewportComboItem" Content="Left"/>
                                                <ComboBoxItem Classes="MaxViewportComboItem" Content="Right"/>
                                                <ComboBoxItem Classes="MaxViewportComboItem" Content="Back"/>
                                                <ComboBoxItem Classes="MaxViewportComboItem" Content="Bottom"/>
                                            </ComboBox>
                                            <ComboBox Classes="MaxViewportCombo"
                                                      SelectedIndex="{Binding Toolbar.Options.ViewportShadingIndex, Mode=TwoWay}">
                                                <ComboBoxItem Classes="MaxViewportComboItem" Content="Default Shading"/>
                                                <ComboBoxItem Classes="MaxViewportComboItem" Content="Wireframe"/>
                                                <ComboBoxItem Classes="MaxViewportComboItem" Content="Unlit"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>
                                    <Border Classes="MaxViewCube"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="8"
                                            IsHitTestVisible="False">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="View" Classes="MaxViewCubeText"/>
                                            <TextBlock Text="Cube" Classes="MaxViewCubeText"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Classes="MaxViewportHud"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            Margin="8"
                                            IsHitTestVisible="False">
                                        <TextBlock Text="{Binding Toolbar.Options.ViewportHudLabel}"
                                                   Classes="MaxViewportHudText"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="360"/>
                                    </Border>
                                    <Border Classes="MaxViewportReadout"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="8"
                                            IsHitTestVisible="False">
                                        <TextBlock Text="{Binding Toolbar.Options.ViewportOverlayStatusLabel}"
                                                   Classes="MaxViewportReadoutText"
                                                   TextWrapping="NoWrap"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Spacing="4"
                                                Margin="8">
                                        <ToggleButton Classes="MaxViewportNavButton"
                                                      ToolTip.Tip="Zoom"
                                                      IsChecked="{Binding Toolbar.Options.IsNavZoom, Mode=TwoWay}">
                                            <TextBlock Text="Z" Classes="MaxViewportNavGlyph"/>
                                        </ToggleButton>
                                        <ToggleButton Classes="MaxViewportNavButton"
                                                      ToolTip.Tip="Pan"
                                                      IsChecked="{Binding Toolbar.Options.IsNavPan, Mode=TwoWay}">
                                            <TextBlock Text="P" Classes="MaxViewportNavGlyph"/>
                                        </ToggleButton>
                                        <ToggleButton Classes="MaxViewportNavButton"
                                                      ToolTip.Tip="Orbit"
                                                      IsChecked="{Binding Toolbar.Options.IsNavOrbit, Mode=TwoWay}">
                                            <TextBlock Text="O" Classes="MaxViewportNavGlyph"/>
                                        </ToggleButton>
                                        <ToggleButton Classes="MaxViewportNavButton"
                                                      ToolTip.Tip="Universal"
                                                      IsChecked="{Binding Toolbar.Options.IsNavDefault, Mode=TwoWay}">
                                            <TextBlock Text="U" Classes="MaxViewportNavGlyph"/>
                                        </ToggleButton>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                <primitives:Popup IsOpen="{Binding Actions.IsQuadMenuOpen, Mode=TwoWay}"
                                  x:Name="QuadMenuPopup"
                                  PlacementTarget="{Binding ElementName=ViewportPerspective}"
                                  Placement="Pointer"
                                  HorizontalOffset="8"
                                  VerticalOffset="8"
                                  IsLightDismissEnabled="True">
                    <controls:QuadMenuControl DataContext="{Binding}"/>
                </primitives:Popup>
            </Grid>
            <Grid Grid.Column="2"
                  IsVisible="{Binding Workspace.ShowCommandPanel}">
                <controls:CommandPanelControl x:Name="OptionsPanel"
                                              DataContext="{Binding CommandPanel}"/>
            </Grid>
        </Grid>
        <Grid Grid.Row="5"
              IsVisible="{Binding Workspace.ShowStatusBar}">
            <controls:StatusBarControl DataContext="{Binding}"/>
        </Grid>
    </Grid>
</Window>

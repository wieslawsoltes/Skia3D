        </Style>
        <Style Selector="ComboBox.ToolbarCombo">
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
        <Style Selector="Expander.InspectorRollout">

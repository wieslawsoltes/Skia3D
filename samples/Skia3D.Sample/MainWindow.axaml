            <Setter Property="Foreground" Value="#E4E8EE"/>
        </Style>
        <Style Selector="Border.GraphCanvas">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#24292F" Offset="0"/>
                    <GradientStop Color="#1F242A" Offset="1"/>
                </LinearGradientBrush>

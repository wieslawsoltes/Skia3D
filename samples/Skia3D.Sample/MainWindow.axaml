        </Style>
        <Style Selector="TabItem.CommandTab:selected TextBlock.CommandTabLabel">
            <Setter Property="Foreground" Value="#E4E8EE"/>
        </Style>
        <Style Selector="ToggleButton.MaxPanelTab">
